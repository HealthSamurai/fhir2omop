{
  "resourceType": "ViewDefinition",
  "id": "omop-specimen-specimen",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-specimen-specimen",
  "version": "0.2.0",
  "name": "OmopSpecimenSpecimenView",
  "title": "Specimen → specimen (FHIR-flat, stage 1)",
  "status": "draft",
  "experimental": true,
  "description": "One FHIR Specimen maps to exactly one OMOP specimen row. The specimen table captures biological samples collected from a person, including specimen type, collection date, quantity, anatomic site, and disease status. Specimen type (kind of material) maps to specimen_concept_id via SNOMED, while specimen_type_concept_id is a provenance metadata field (EHR = 32817). Collection date is required in OMOP but optional in FHIR.\n\nStage 1 of FHIR→OMOP: produce a flat row keeping source codes per vocabulary. Stage 2 joins vocab.concept to resolve concept_ids.",
  "extension": [
    {
      "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table",
      "valueString": "specimen"
    },
    {
      "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",
      "valueString": "Specimen__specimen"
    }
  ],
  "resource": "Specimen",
  "select": [
    {
      "column": [
        {
          "name": "id",
          "path": "Specimen.id",
          "type": "id",
          "description": "FHIR Specimen.id; surrogate OMOP key derived (hash/sequence) downstream.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "specimen_id"
                },
                {
                  "url": "transform",
                  "valueString": "surrogate key from hash/sequence/lookup of FHIR id"
                }
              ]
            }
          ]
        },
        {
          "name": "type_snomed",
          "path": "Specimen.type.coding.where(system='http://snomed.info/sct').first().code",
          "type": "code",
          "description": "Specimen type — SNOMED",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "specimen_concept_id"
                },
                {
                  "url": "transform",
                  "valueString": "lookup vocab.concept WHERE vocabulary_id='SNOMED' AND concept_code = (this column); standard_concept='S' preferred"
                }
              ]
            }
          ]
        },
        {
          "name": "type_text",
          "path": "Specimen.type.text",
          "type": "string",
          "description": "Free text label from Specimen.type",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "specimen_source_value"
                },
                {
                  "url": "transform",
                  "valueString": "copy text verbatim into OMOP source_value column"
                }
              ]
            }
          ]
        },
        {
          "name": "body_site_snomed",
          "path": "Specimen.collection.bodySite.coding.where(system='http://snomed.info/sct').first().code",
          "type": "code",
          "description": "Body site — SNOMED",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "specimen_type_concept_id"
                },
                {
                  "url": "transform",
                  "valueString": "lookup vocab.concept WHERE vocabulary_id='SNOMED' AND concept_code = (this column); standard_concept='S' preferred"
                }
              ]
            }
          ]
        },
        {
          "name": "body_site_text",
          "path": "Specimen.collection.bodySite.text",
          "type": "string",
          "description": "Free text label from Specimen.collection.bodySite",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "specimen_type_source_value"
                },
                {
                  "url": "transform",
                  "valueString": "copy text verbatim into OMOP source_value column"
                }
              ]
            }
          ]
        },
        {
          "name": "unit_ucum",
          "path": "Specimen.collection.quantity.code.coding.where(system='http://unitsofmeasure.org').first().code",
          "type": "code",
          "description": "Unit of measure — UCUM",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "unit_concept_id"
                },
                {
                  "url": "transform",
                  "valueString": "lookup vocab.concept WHERE vocabulary_id='UCUM' AND concept_code = (this column); standard_concept='S' preferred"
                }
              ]
            }
          ]
        },
        {
          "name": "unit_text",
          "path": "Specimen.collection.quantity.code.text",
          "type": "string",
          "description": "Free text label from Specimen.collection.quantity.code",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "unit_source_value"
                },
                {
                  "url": "transform",
                  "valueString": "copy text verbatim into OMOP source_value column"
                }
              ]
            }
          ]
        },
        {
          "name": "subject_id",
          "path": "Specimen.subject",
          "type": "Reference(Patient)",
          "description": "Resolve Patient reference to integer person_id. Subject must be a Patient -- reject Device, Group, Location, Substance subjects.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "person_id"
                },
                {
                  "url": "transform",
                  "valueString": "resolve_patient_reference(Specimen.subject)"
                }
              ]
            }
          ]
        },
        {
          "name": "specimen_date",
          "path": "Specimen.collection.collected[x]",
          "type": "dateTime | Period",
          "description": "OMOP requires this field (NOT NULL). If collected[x] is a Period, use Period.start. If absent, try Specimen.receivedTime as fallback.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "specimen_date"
                },
                {
                  "url": "transform",
                  "valueString": "date_component(collected[x]); if Period use Period.start; fallback to Specimen.receivedTime"
                }
              ]
            }
          ]
        },
        {
          "name": "specimen_datetime",
          "path": "Specimen.collection.collected[x]",
          "type": "dateTime | Period",
          "description": "Full datetime of collection. Same source as specimen_date but preserves time component.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "specimen_datetime"
                },
                {
                  "url": "transform",
                  "valueString": "full_datetime(collected[x]); if date-only append T00:00:00"
                }
              ]
            }
          ]
        },
        {
          "name": "quantity",
          "path": "Specimen.collection.quantity.value",
          "type": "decimal",
          "description": "Amount of specimen collected. Direct numeric copy from collection.quantity.value.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "quantity"
                }
              ]
            }
          ]
        },
        {
          "name": "anatomic_site",
          "path": "Specimen.collection.bodySite",
          "type": "CodeableConcept",
          "description": "SNOMED body site code mapped to OMOP concept. Use first coding from bodySite.coding[]. Default 0 if unmapped.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "anatomic_site_concept_id"
                },
                {
                  "url": "transform",
                  "valueString": "resolve CONCEPT reference; downstream maps to anatomic_site_concept_id"
                }
              ]
            }
          ]
        },
        {
          "name": "anatomic_site_text",
          "path": "Specimen.collection.bodySite.text",
          "type": "string",
          "description": "Source text for anatomic site. Prefer bodySite.text, then coding[0].display, then coding[0].code.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "anatomic_site_source_value"
                }
              ]
            }
          ]
        },
        {
          "name": "disease_status",
          "path": "Specimen.condition",
          "type": "CodeableConcept",
          "description": "Semantic mismatch: FHIR condition describes specimen quality (hemolyzed, lipemic), not patient disease status. Most implementations set 0.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "disease_status_concept_id"
                },
                {
                  "url": "transform",
                  "valueString": "resolve CONCEPT reference; downstream maps to disease_status_concept_id"
                }
              ]
            }
          ]
        },
        {
          "name": "disease_status_text",
          "path": "Specimen.condition.text",
          "type": "string",
          "description": "Source text for disease/condition status. Prefer condition.text, then coding[0].display, then coding[0].code.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "disease_status_source_value"
                }
              ]
            }
          ]
        },
        {
          "name": "specimen_source_id",
          "path": "Specimen.identifier[0].value",
          "type": "string",
          "description": "Source system identifier. omoponfhir uses first identifier value. Can also use Specimen.accessionIdentifier.value.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "specimen_source_id"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
