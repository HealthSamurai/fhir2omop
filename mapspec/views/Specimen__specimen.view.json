{
  "resourceType": "ViewDefinition",
  "id": "omop-specimen-specimen",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-specimen-specimen",
  "name": "OmopSpecimenSpecimenView",
  "title": "Specimen → specimen (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "specimen" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "Specimen__specimen" }
  ],
  "resource": "Specimen",
  "description": "Specimen → specimen row. Synthea doesn't emit Specimen.",
  "constant": [
    { "name": "snomedSystem", "valueString": "http://snomed.info/sct" }
  ],
  "select": [
    {
      "column": [
        { "name": "id",              "path": "id",                                                             "type": "id" },
        { "name": "subject_ref",     "path": "subject.getReferenceKey()",                                       "type": "string" },
        { "name": "type_snomed",     "path": "type.coding.where(system=%snomedSystem).code.first()",            "type": "code" },
        { "name": "body_site_snomed","path": "collection.bodySite.coding.where(system=%snomedSystem).code.first()", "type": "code" },
        { "name": "collected_dt",    "path": "collection.collected.ofType(dateTime)",                           "type": "dateTime" },
        { "name": "quantity_value",  "path": "collection.quantity.value",                                       "type": "decimal" }
      ]
    }
  ]
}
