{
  "resourceType": "ViewDefinition",
  "id": "omop-patient-death",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-patient-death",
  "name": "OmopPatientDeathView",
  "title": "Patient → death (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "death" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "Patient__death" }
  ],
  "resource": "Patient",
  "description": "Mortality record. At most one row per person, only when deceasedDateTime is present (deceasedBoolean=true without a date can't produce a row — death_date is NOT NULL).",
  "select": [
    {
      "column": [
        { "name": "id",        "path": "id",                        "type": "id",       "description": "Patient.id → person_id." },
        { "name": "death_dt",  "path": "deceased.ofType(dateTime)", "type": "dateTime", "description": "deceasedDateTime → death_date / death_datetime." }
      ]
    }
  ]
}
