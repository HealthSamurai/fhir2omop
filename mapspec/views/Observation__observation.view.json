{
  "resourceType": "ViewDefinition",
  "id": "omop-observation-observation",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-observation-observation",
  "name": "OmopObservationObservationView",
  "title": "Observation → observation (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    {
      "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table",
      "valueString": "observation"
    },
    {
      "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",
      "valueString": "Observation__observation"
    }
  ],
  "resource": "Observation",
  "description": "Qualitative findings: social history, survey responses, activity data.\n\nStage 1 of FHIR→OMOP: flat row per Observation, preserving raw FHIR. Code→concept_id resolution happens in stage 2 against vocab.concept using the (system, code) pair.\n\nSame compact shape as Observation__measurement.view.json (one column per concept-position). Adds value_string and qualifier columns; drops operator and reference range columns which OMOP observation doesn't carry.",
  "select": [
    {
      "column": [
        {
          "name": "id",
          "path": "Observation.id",
          "type": "id",
          "description": "FHIR Observation.id; → surrogate observation_id (hash/sequence in stage 2)."
        },
        {
          "name": "subject_id",
          "path": "Observation.subject.getReferenceKey()",
          "type": "string",
          "description": "FHIR reference string. → person_id by trailing segment."
        },
        {
          "name": "encounter_id",
          "path": "Observation.encounter.getReferenceKey()",
          "type": "string",
          "description": "FHIR encounter reference. → visit_occurrence_id."
        },
        {
          "name": "performer_id",
          "path": "Observation.performer.first().getReferenceKey()",
          "type": "string",
          "description": "First performer reference. → provider_id."
        },

        {
          "name": "code_system",
          "path": "Observation.code.coding.first().system",
          "type": "uri",
          "description": "Code system URL of first coding. Mapped to OMOP vocabulary_id via system-aliases."
        },
        {
          "name": "code_value",
          "path": "Observation.code.coding.first().code",
          "type": "code",
          "description": "Source code → observation_concept_id (after Maps-to). Also kept verbatim as observation_source_value."
        },
        {
          "name": "code_text",
          "path": "Observation.code.text",
          "type": "string",
          "description": "Free-text label → fallback observation_source_value."
        },

        {
          "name": "effective_dt",
          "path": "Observation.effective.ofType(dateTime)",
          "type": "dateTime",
          "description": "effectiveDateTime branch. → observation_date / observation_datetime."
        },
        {
          "name": "effective_period_start",
          "path": "Observation.effective.ofType(Period).start",
          "type": "dateTime",
          "description": "effectivePeriod.start fallback."
        },

        {
          "name": "value_number",
          "path": "Observation.valueQuantity.value",
          "type": "decimal",
          "description": "Numeric value. → value_as_number."
        },
        {
          "name": "value_string",
          "path": "Observation.valueString",
          "type": "string",
          "description": "String value (OMOP observation supports this; measurement does not). → value_as_string."
        },
        {
          "name": "value_unit_code",
          "path": "Observation.valueQuantity.code",
          "type": "code",
          "description": "UCUM unit code. → unit_concept_id."
        },
        {
          "name": "value_unit_text",
          "path": "Observation.valueQuantity.unit",
          "type": "string",
          "description": "Human-readable unit. → unit_source_value."
        },

        {
          "name": "value_code_system",
          "path": "Observation.valueCodeableConcept.coding.first().system",
          "type": "uri",
          "description": "When value[x] is a CodeableConcept: system URL of first coding."
        },
        {
          "name": "value_code",
          "path": "Observation.valueCodeableConcept.coding.first().code",
          "type": "code",
          "description": "Coded value → value_as_concept_id."
        },
        {
          "name": "value_text",
          "path": "Observation.valueCodeableConcept.text",
          "type": "string",
          "description": "Free-text answer or assembled summary. → value_source_value."
        },

        {
          "name": "qualifier_system",
          "path": "Observation.interpretation.first().coding.first().system",
          "type": "uri",
          "description": "HL7 ObservationInterpretation system (or SNOMED). → qualifier_concept_id via Maps-to."
        },
        {
          "name": "qualifier_code",
          "path": "Observation.interpretation.first().coding.first().code",
          "type": "code",
          "description": "Interpretation code (H/L/N/A/AA/…) → qualifier_concept_id. Verbatim → qualifier_source_value."
        }
      ]
    }
  ]
}
