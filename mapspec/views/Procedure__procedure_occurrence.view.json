{
  "resourceType": "ViewDefinition",
  "id": "omop-procedure-procedure-occurrence",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-procedure-procedure-occurrence",
  "name": "OmopProcedureProcedureOccurrenceView",
  "title": "Procedure → procedure_occurrence (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "procedure_occurrence" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "Procedure__procedure_occurrence" }
  ],
  "resource": "Procedure",
  "description": "One Procedure → one procedure_occurrence row. Code fan-out per known vocabulary (SNOMED preferred since already standard for OMOP Procedure domain; CPT4/HCPCS/ICD10PCS fallback). Stage 2 routes by vocab.concept.domain_id='Procedure'.",
  "constant": [
    { "name": "snomedSystem",   "valueString": "http://snomed.info/sct" },
    { "name": "cpt4System",     "valueString": "http://www.ama-assn.org/go/cpt" },
    { "name": "hcpcsSystem",    "valueString": "https://www.cms.gov/Medicare/Coding/HCPCSReleaseCodeSets" },
    { "name": "icd10pcsSystem", "valueString": "http://hl7.org/fhir/sid/icd-10-pcs" }
  ],
  "select": [
    {
      "column": [
        { "name": "id",                  "path": "id",                                                       "type": "id",       "description": "FHIR Procedure.id → hash → procedure_occurrence_id." },
        { "name": "status",              "path": "status",                                                   "type": "code",     "description": "Stage-2 filters 'entered-in-error', 'not-done', 'unknown' so cancelled procedures don't become facts." },
        { "name": "subject_ref",         "path": "subject.getReferenceKey()",                                "type": "string",   "description": "→ person_id (hash)." },
        { "name": "encounter_ref",       "path": "encounter.getReferenceKey()",                              "type": "string",   "description": "→ visit_occurrence_id (hash)." },
        { "name": "code_snomed",         "path": "code.coding.where(system=%snomedSystem).code.first()",     "type": "code",     "description": "SNOMED CT — preferred." },
        { "name": "code_cpt4",           "path": "code.coding.where(system=%cpt4System).code.first()",       "type": "code",     "description": "CPT-4 — fallback." },
        { "name": "code_hcpcs",          "path": "code.coding.where(system=%hcpcsSystem).code.first()",      "type": "code",     "description": "HCPCS — fallback." },
        { "name": "code_icd10pcs",       "path": "code.coding.where(system=%icd10pcsSystem).code.first()",   "type": "code",     "description": "ICD-10-PCS — fallback." },
        { "name": "code_text",           "path": "code.text",                                                "type": "string",   "description": "Human-readable label." },
        { "name": "performed_dt",        "path": "performed.ofType(dateTime)",                               "type": "dateTime", "description": "performedDateTime branch." },
        { "name": "performed_period_start", "path": "performed.ofType(Period).start",                        "type": "dateTime", "description": "performedPeriod.start." },
        { "name": "performed_period_end",   "path": "performed.ofType(Period).end",                          "type": "dateTime", "description": "performedPeriod.end → procedure_end_date." },
        { "name": "performer_ref",       "path": "performer.first().actor.getReferenceKey()",                "type": "string",   "description": "First performer.actor (Practitioner) → provider_id." },
        { "name": "status_code",         "path": "status",                                                   "type": "code",     "description": "preparation/in-progress/completed/etc." }
      ]
    }
  ]
}
