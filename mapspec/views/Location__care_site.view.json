{
  "resourceType": "ViewDefinition",
  "id": "omop-location-care-site",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-location-care-site",
  "name": "OmopLocationCareSiteView",
  "title": "Location → care_site (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "care_site" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "Location__care_site" }
  ],
  "resource": "Location",
  "description": "Hospitals/clinics as care_site, keyed by Location.id (separate from Organization__care_site keyed by Organization.id). Appends.",
  "constant": [
    { "name": "snomedSystem", "valueString": "http://snomed.info/sct" }
  ],
  "select": [
    {
      "column": [
        { "name": "id",        "path": "id",                                                       "type": "id" },
        { "name": "name",      "path": "name",                                                     "type": "string" },
        { "name": "type_code", "path": "type.first().coding.where(system=%snomedSystem).code.first()", "type": "code" }
      ]
    }
  ]
}
