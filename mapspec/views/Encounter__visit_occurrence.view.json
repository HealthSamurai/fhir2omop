{
  "resourceType": "ViewDefinition",
  "id": "omop-encounter-visit-occurrence",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-encounter-visit-occurrence",
  "version": "0.2.0",
  "name": "OmopEncounterVisitOccurrenceView",
  "title": "Encounter → visit_occurrence (FHIR-flat, stage 1)",
  "status": "draft",
  "experimental": true,
  "description": "One FHIR Encounter maps to one visit_occurrence row. The visit_occurrence table is the OMOP anchor for linking clinical events to a care context -- every event table (condition_occurrence, measurement, drug_exposure, etc.) carries a visit_occurrence_id FK. Encounter.class maps to visit_concept_id via a small lookup table; period maps to start/end dates; participant maps to provider_id; serviceProvider maps to care_site_id. Planned and cancelled encounters are dropped.\n\nStage 1 of FHIR→OMOP: produce a flat row keeping source codes per vocabulary. Stage 2 joins vocab.concept to resolve concept_ids.",
  "extension": [
    {
      "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table",
      "valueString": "visit_occurrence"
    },
    {
      "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",
      "valueString": "Encounter__visit_occurrence"
    }
  ],
  "resource": "Encounter",
  "select": [
    {
      "column": [
        {
          "name": "id",
          "path": "Encounter.id",
          "type": "id",
          "description": "FHIR Encounter.id; surrogate OMOP key derived (hash/sequence) downstream.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "visit_occurrence_id"
                },
                {
                  "url": "transform",
                  "valueString": "surrogate key from hash/sequence/lookup of FHIR id"
                }
              ]
            }
          ]
        },
        {
          "name": "class_actcode",
          "path": "Encounter.class.coding.where(system='http://terminology.hl7.org/CodeSystem/v3-ActCode').first().code",
          "type": "code",
          "description": "Encounter class (AMB/IMP/EMER/...) — ActCode",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "visit_concept_id"
                },
                {
                  "url": "transform",
                  "valueString": "lookup vocab.concept WHERE vocabulary_id='ActCode' AND concept_code = (this column); standard_concept='S' preferred"
                }
              ]
            }
          ]
        },
        {
          "name": "class_text",
          "path": "Encounter.class.text",
          "type": "string",
          "description": "Free text label from Encounter.class",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "visit_source_value"
                },
                {
                  "url": "transform",
                  "valueString": "copy text verbatim into OMOP source_value column"
                }
              ]
            }
          ]
        },
        {
          "name": "type_snomed",
          "path": "Encounter.type.coding.where(system='http://snomed.info/sct').first().code",
          "type": "code",
          "description": "Encounter type — SNOMED",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "visit_type_concept_id"
                },
                {
                  "url": "transform",
                  "valueString": "lookup vocab.concept WHERE vocabulary_id='SNOMED' AND concept_code = (this column); standard_concept='S' preferred"
                }
              ]
            }
          ]
        },
        {
          "name": "type_cpt",
          "path": "Encounter.type.coding.where(system='http://www.ama-assn.org/go/cpt').first().code",
          "type": "code",
          "description": "Encounter type — CPT4",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "visit_type_concept_id"
                },
                {
                  "url": "transform",
                  "valueString": "lookup vocab.concept WHERE vocabulary_id='CPT4' AND concept_code = (this column); standard_concept='S' preferred"
                }
              ]
            }
          ]
        },
        {
          "name": "type_text",
          "path": "Encounter.type.text",
          "type": "string",
          "description": "Free text label from Encounter.type",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "visit_type_source_value"
                },
                {
                  "url": "transform",
                  "valueString": "copy text verbatim into OMOP source_value column"
                }
              ]
            }
          ]
        },
        {
          "name": "subject_id",
          "path": "Encounter.subject",
          "type": "Reference(Patient)",
          "description": "Resolve Patient reference. omoponfhir throws FHIRException if absent. ETL-German looks up by identifier or logical ID. Our project uses ctx.ids.resolveRef(), defaults to 0 if unresolved.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "person_id"
                },
                {
                  "url": "transform",
                  "valueString": "resolve PERSON reference; downstream maps to person_id"
                }
              ]
            }
          ]
        },
        {
          "name": "visit_start_date",
          "path": "Encounter.period.start",
          "type": "dateTime",
          "description": "Date portion (YYYY-MM-DD). Skip encounter if absent (our project, ETL-German). omoponfhir writes epoch 0 if absent.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "visit_start_date"
                },
                {
                  "url": "transform",
                  "valueString": "date(Encounter.period.start)"
                }
              ]
            }
          ]
        },
        {
          "name": "visit_start_datetime",
          "path": "Encounter.period.start",
          "type": "dateTime",
          "description": "Full ISO datetime. omoponfhir copies the start Date object directly.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "visit_start_datetime"
                }
              ]
            }
          ]
        },
        {
          "name": "visit_end_date",
          "path": "Encounter.period.end",
          "type": "dateTime",
          "description": "If absent, use visit_start_date (our project, NACHC, FhirToCdm). ETL-German uses LocalDate.now() for still-admitted patients.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "visit_end_date"
                },
                {
                  "url": "transform",
                  "valueString": "date(Encounter.period.end) ?? visit_start_date"
                }
              ]
            }
          ]
        },
        {
          "name": "visit_end_datetime",
          "path": "Encounter.period.end",
          "type": "dateTime",
          "description": "Full ISO datetime; null if absent. ETL-German uses LocalDateTime.now() for CONCEPT_STILL_PATIENT cases.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "visit_end_datetime"
                }
              ]
            }
          ]
        },
        {
          "name": "performer_id",
          "path": "Encounter.participant[0].individual",
          "type": "Reference(Practitioner)",
          "description": "First Practitioner-typed participant (our project). omoponfhir uses getParticipantFirstRep(). fhir-to-omop-demo filters for PPRF (primary performer). fhir-x-omop filters for ATND (attending). NACHC defaults to 1.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "provider_id"
                },
                {
                  "url": "transform",
                  "valueString": "resolve PROVIDER reference; downstream maps to provider_id"
                }
              ]
            }
          ]
        },
        {
          "name": "managing_organization_id",
          "path": "Encounter.serviceProvider",
          "type": "Reference(Organization)",
          "description": "Organization reference. Our project resolves via ctx.ids.resolveRef(). omoponfhir resolves via IdMapping. FhirToCdm creates a Provider from serviceProvider.display. NACHC defaults to 1.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "care_site_id"
                },
                {
                  "url": "transform",
                  "valueString": "resolve CARE_SITE reference; downstream maps to care_site_id"
                }
              ]
            }
          ]
        },
        {
          "name": "admitted_from",
          "path": "Encounter.hospitalization.admitSource",
          "type": "CodeableConcept",
          "description": "Requires vocabulary lookup. 0 if unmapped (our project, FhirToCdm). ETL-German stores in post_process_map for deferred resolution. No implementation in the reference set performs a complete vocabulary lookup.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "admitted_from_concept_id"
                },
                {
                  "url": "transform",
                  "valueString": "resolve CONCEPT reference; downstream maps to admitted_from_concept_id"
                }
              ]
            }
          ]
        },
        {
          "name": "admitted_from_text",
          "path": "Encounter.hospitalization.admitSource",
          "type": "CodeableConcept",
          "description": "Raw admit source code. Our project extracts via getSourceValue() and truncates to 50 chars. NACHC stores 'Not Available'.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "admitted_from_source_value"
                },
                {
                  "url": "transform",
                  "valueString": "getSourceValue(admitSource).truncate(50)"
                }
              ]
            }
          ]
        },
        {
          "name": "discharged_to",
          "path": "Encounter.hospitalization.dischargeDisposition",
          "type": "CodeableConcept",
          "description": "Requires vocabulary lookup. 0 if unmapped (our project). fhir-x-omop maps home->8536, snf->8676, rehab->8615, exp->4216643. Most implementations default to 0.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "discharged_to_concept_id"
                },
                {
                  "url": "transform",
                  "valueString": "resolve CONCEPT reference; downstream maps to discharged_to_concept_id"
                }
              ]
            }
          ]
        },
        {
          "name": "discharged_to_text",
          "path": "Encounter.hospitalization.dischargeDisposition",
          "type": "CodeableConcept",
          "description": "Raw discharge code. Our project extracts via getSourceValue(). fhir-x-omop uses the display.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "discharged_to_source_value"
                },
                {
                  "url": "transform",
                  "valueString": "getSourceValue(dischargeDisposition).truncate(50)"
                }
              ]
            }
          ]
        },
        {
          "name": "preceding_visit_occurrence_id",
          "path": "Encounter.partOf",
          "type": "Reference(Encounter)",
          "description": "Previous encounter in a chain. Not widely used for this field; most implementations use partOf to link child encounters via visit_detail instead.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "preceding_visit_occurrence_id"
                },
                {
                  "url": "transform",
                  "valueString": "resolve VISIT_OCCURRENCE reference; downstream maps to preceding_visit_occurrence_id"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
