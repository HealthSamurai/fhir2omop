{
  "resourceType": "ViewDefinition",
  "id": "omop-diagnosticreport-procedure-occurrence",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-diagnosticreport-procedure-occurrence",
  "name": "OmopDiagnosticReportProcedureOccurrenceView",
  "title": "DiagnosticReport → procedure_occurrence (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "procedure_occurrence" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "DiagnosticReport__procedure_occurrence" }
  ],
  "resource": "DiagnosticReport",
  "description": "DR code routed to Procedure domain (e.g., imaging studies). Appends to cdm_ours_fhir.procedure_occurrence.",
  "constant": [
    { "name": "loincSystem",   "valueString": "http://loinc.org" },
    { "name": "snomedSystem",  "valueString": "http://snomed.info/sct" },
    { "name": "cpt4System",    "valueString": "http://www.ama-assn.org/go/cpt" }
  ],
  "select": [
    {
      "column": [
        { "name": "id",            "path": "id",                                                      "type": "id" },
        { "name": "subject_ref",   "path": "subject.getReferenceKey()",                                "type": "string" },
        { "name": "encounter_ref", "path": "encounter.getReferenceKey()",                              "type": "string" },
        { "name": "performer_ref",              "path": "performer.first().getReferenceKey()",                                                  "type": "string", "description": "DEPRECATED untyped first performer — kept for compatibility but mixes Practitioner and Organization references. Use the typed siblings below." },
        { "name": "performer_practitioner_ref", "path": "performer.where(reference.startsWith('Practitioner/')).first().getReferenceKey()",   "type": "string", "description": "First Practitioner-typed performer. → provider_id." },
        { "name": "performer_organization_ref", "path": "performer.where(reference.startsWith('Organization/')).first().getReferenceKey()",   "type": "string", "description": "First Organization-typed performer (lab/facility). Not consumed by stage-2; preserved for traceability." },
        { "name": "code_loinc",    "path": "code.coding.where(system=%loincSystem).code.first()",      "type": "code" },
        { "name": "code_snomed",   "path": "code.coding.where(system=%snomedSystem).code.first()",     "type": "code" },
        { "name": "code_cpt4",     "path": "code.coding.where(system=%cpt4System).code.first()",       "type": "code" },
        { "name": "code_text",     "path": "code.text",                                                "type": "string" },
        { "name": "effective_dt",  "path": "effective.ofType(dateTime)",                               "type": "dateTime" }
      ]
    }
  ]
}
