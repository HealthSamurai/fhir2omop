{
  "resourceType": "ViewDefinition",
  "id": "omop-device-device-exposure",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-device-device-exposure",
  "name": "OmopDeviceDeviceExposureView",
  "title": "Device → device_exposure (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "device_exposure" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "Device__device_exposure" }
  ],
  "resource": "Device",
  "description": "One Device → one device_exposure row. SNOMED Device-domain concept. NOTE: FHIR Device has no temporal field — Synthea's FHIR export omits the timing info the CSV carries. Real-world data should pair Device with DeviceUseStatement; we extract what's available here.",
  "constant": [
    { "name": "snomedSystem", "valueString": "http://snomed.info/sct" }
  ],
  "select": [
    {
      "column": [
        { "name": "id",          "path": "id",                                                       "type": "id",     "description": "→ device_exposure_id (hash)." },
        { "name": "subject_ref", "path": "patient.getReferenceKey()",                                 "type": "string", "description": "Patient → person_id." },
        { "name": "code_snomed", "path": "type.coding.where(system=%snomedSystem).code.first()",      "type": "code",   "description": "SNOMED physical object code." },
        { "name": "code_text",   "path": "type.text",                                                 "type": "string", "description": "Device display name." },
        { "name": "udi",         "path": "udiCarrier.first().deviceIdentifier",                       "type": "string", "description": "UDI-DI → device_source_value fallback." },
        { "name": "lot_number",  "path": "lotNumber",                                                 "type": "string", "description": "→ device_exposure.lot_number." },
        { "name": "status_code", "path": "status",                                                    "type": "code",   "description": "active / inactive / entered-in-error / unknown." },
        { "name": "manufacture_date", "path": "manufactureDate",                                      "type": "dateTime", "description": "Manufacture date. Used as a deterministic placeholder for device_exposure_start_date when no implantation date is available. NOT the implantation date." },
        { "name": "expiration_date",  "path": "expirationDate",                                       "type": "dateTime", "description": "Expiration date. Used as a deterministic placeholder for device_exposure_end_date." }
      ]
    }
  ]
}
