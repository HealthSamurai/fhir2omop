{
  "resourceType": "ViewDefinition",
  "id": "omop-medicationadministration-drug-exposure",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-medicationadministration-drug-exposure",
  "name": "OmopMedicationAdministrationDrugExposureView",
  "title": "MedicationAdministration → drug_exposure (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "drug_exposure" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "MedicationAdministration__drug_exposure" }
  ],
  "resource": "MedicationAdministration",
  "description": "Drug actually administered. RxNorm preferred. drug_type_concept_id 38000179 'Inpatient administration'. NOTE: Synthea also writes the same drug to MedicationRequest — the union covers prescribed + administered.",
  "constant": [
    { "name": "rxnormSystem", "valueString": "http://www.nlm.nih.gov/research/umls/rxnorm" },
    { "name": "ndcSystem",    "valueString": "http://hl7.org/fhir/sid/ndc" },
    { "name": "snomedSystem", "valueString": "http://snomed.info/sct" }
  ],
  "select": [
    {
      "column": [
        { "name": "id",            "path": "id",                                                                                "type": "id",       "description": "MedicationAdministration.id → hash → drug_exposure_id." },
        { "name": "subject_ref",   "path": "subject.getReferenceKey()",                                                          "type": "string",   "description": "Patient → person_id." },
        { "name": "encounter_ref", "path": "context.getReferenceKey()",                                                          "type": "string",   "description": "Encounter (R4 'context') → visit_occurrence_id." },
        { "name": "code_rxnorm",   "path": "medication.ofType(CodeableConcept).coding.where(system=%rxnormSystem).code.first()", "type": "code",     "description": "RxNorm." },
        { "name": "code_ndc",      "path": "medication.ofType(CodeableConcept).coding.where(system=%ndcSystem).code.first()",    "type": "code",     "description": "NDC fallback." },
        { "name": "code_snomed",   "path": "medication.ofType(CodeableConcept).coding.where(system=%snomedSystem).code.first()", "type": "code",     "description": "SNOMED last-resort." },
        { "name": "code_text",     "path": "medication.ofType(CodeableConcept).text",                                            "type": "string",   "description": "Drug label." },
        { "name": "effective_dt",  "path": "effective.ofType(dateTime)",                                                         "type": "dateTime", "description": "effectiveDateTime → start_date/datetime." },
        { "name": "status_code",   "path": "status",                                                                             "type": "code",     "description": "completed / in-progress / stopped / entered-in-error." }
      ]
    }
  ]
}
