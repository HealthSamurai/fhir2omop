{
  "resourceType": "ViewDefinition",
  "id": "omop-diagnosticreport-measurement",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-diagnosticreport-measurement",
  "name": "OmopDiagnosticReportMeasurementView",
  "title": "DiagnosticReport → measurement (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "measurement" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "DiagnosticReport__measurement" }
  ],
  "resource": "DiagnosticReport",
  "description": "DR's own code (typically a LOINC panel like '24323-8 Comp Metabolic Panel') routed to measurement domain. Individual result lines come through Observation→measurement separately.",
  "constant": [
    { "name": "loincSystem",  "valueString": "http://loinc.org" },
    { "name": "snomedSystem", "valueString": "http://snomed.info/sct" }
  ],
  "select": [
    {
      "column": [
        { "name": "id",            "path": "id",                                                      "type": "id" },
        { "name": "subject_ref",   "path": "subject.getReferenceKey()",                                "type": "string" },
        { "name": "encounter_ref", "path": "encounter.getReferenceKey()",                              "type": "string" },
        { "name": "performer_ref", "path": "performer.first().getReferenceKey()",                      "type": "string" },
        { "name": "code_loinc",    "path": "code.coding.where(system=%loincSystem).code.first()",      "type": "code" },
        { "name": "code_snomed",   "path": "code.coding.where(system=%snomedSystem).code.first()",     "type": "code" },
        { "name": "code_text",     "path": "code.text",                                                "type": "string" },
        { "name": "effective_dt",  "path": "effective.ofType(dateTime)",                               "type": "dateTime" }
      ]
    }
  ]
}
