{
  "resourceType": "ViewDefinition",
  "id": "omop-allergyintolerance-observation",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-allergyintolerance-observation",
  "name": "OmopAllergyIntoleranceObservationView",
  "title": "AllergyIntolerance → observation (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "observation" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "AllergyIntolerance__observation" }
  ],
  "resource": "AllergyIntolerance",
  "description": "OMOP has no dedicated allergy table — allergies live in `observation`. One AllergyIntolerance → one observation row. The SNOMED finding (or RxNorm substance) is both the source code AND the value (it represents the substance the patient is allergic to).",
  "constant": [
    { "name": "snomedSystem", "valueString": "http://snomed.info/sct" },
    { "name": "rxnormSystem", "valueString": "http://www.nlm.nih.gov/research/umls/rxnorm" }
  ],
  "select": [
    {
      "column": [
        { "name": "id",            "path": "id",                                                                "type": "id",       "description": "→ observation_id (hash)." },
        { "name": "subject_ref",   "path": "patient.getReferenceKey()",                                          "type": "string",   "description": "Patient → person_id." },
        { "name": "encounter_ref", "path": "encounter.getReferenceKey()",                                        "type": "string",   "description": "Encounter → visit_occurrence_id." },
        { "name": "code_snomed",   "path": "code.coding.where(system=%snomedSystem).code.first()",               "type": "code",     "description": "SNOMED allergy/intolerance finding." },
        { "name": "code_rxnorm",   "path": "code.coding.where(system=%rxnormSystem).code.first()",               "type": "code",     "description": "RxNorm substance — for drug allergies." },
        { "name": "code_text",     "path": "code.text",                                                          "type": "string",   "description": "Free-text label." },
        { "name": "recorded_date", "path": "recordedDate",                                                       "type": "dateTime", "description": "→ observation_date / _datetime." },
        { "name": "onset_dt",      "path": "onset.ofType(dateTime)",                                             "type": "dateTime", "description": "Fallback when recordedDate is absent." },
        { "name": "status_code",   "path": "clinicalStatus.coding.first().code",                                 "type": "code",     "description": "active / inactive / resolved." },
        { "name": "verify_status", "path": "verificationStatus.coding.first().code",                             "type": "code",     "description": "confirmed / unconfirmed / refuted / entered-in-error." }
      ]
    }
  ]
}
