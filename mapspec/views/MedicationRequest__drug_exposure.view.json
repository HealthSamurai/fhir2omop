{
  "resourceType": "ViewDefinition",
  "id": "omop-medicationrequest-drug-exposure",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-medicationrequest-drug-exposure",
  "name": "OmopMedicationRequestDrugExposureView",
  "title": "MedicationRequest → drug_exposure (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "drug_exposure" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "MedicationRequest__drug_exposure" }
  ],
  "resource": "MedicationRequest",
  "description": "Medication order → drug_exposure row. RxNorm preferred (already standard OMOP Drug); NDC fallback. drug_type_concept_id 32838 'EHR prescription'.",
  "constant": [
    { "name": "rxnormSystem", "valueString": "http://www.nlm.nih.gov/research/umls/rxnorm" },
    { "name": "ndcSystem",    "valueString": "http://hl7.org/fhir/sid/ndc" }
  ],
  "select": [
    {
      "column": [
        { "name": "id",            "path": "id",                                                                                "type": "id",       "description": "FHIR MedicationRequest.id → hash → drug_exposure_id." },
        { "name": "status",        "path": "status",                                                                            "type": "code",     "description": "MedicationRequest.status. Stage-2 filters out 'entered-in-error', 'cancelled', 'draft', 'unknown' so non-events don't become drug_exposure facts." },
        { "name": "subject_ref",   "path": "subject.getReferenceKey()",                                                          "type": "string",   "description": "Patient → person_id." },
        { "name": "encounter_ref", "path": "encounter.getReferenceKey()",                                                        "type": "string",   "description": "Encounter → visit_occurrence_id." },
        { "name": "requester_ref", "path": "requester.getReferenceKey()",                                                        "type": "string",   "description": "Practitioner → provider_id." },
        { "name": "code_rxnorm",   "path": "medication.ofType(CodeableConcept).coding.where(system=%rxnormSystem).code.first()", "type": "code",     "description": "RxNorm code (Synthea default)." },
        { "name": "code_ndc",      "path": "medication.ofType(CodeableConcept).coding.where(system=%ndcSystem).code.first()",    "type": "code",     "description": "NDC fallback." },
        { "name": "code_text",     "path": "medication.ofType(CodeableConcept).text",                                            "type": "string",   "description": "Drug display label." },
        { "name": "authored_on",   "path": "authoredOn",                                                                         "type": "dateTime", "description": "When prescribed → drug_exposure_start_datetime." },
        { "name": "status_code",   "path": "status",                                                                             "type": "code",     "description": "active / completed / on-hold / cancelled / stopped." }
      ]
    }
  ]
}
