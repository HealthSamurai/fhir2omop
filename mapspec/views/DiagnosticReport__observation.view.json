{
  "resourceType": "ViewDefinition",
  "id": "omop-diagnosticreport-observation",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-diagnosticreport-observation",
  "version": "0.2.0",
  "name": "OmopDiagnosticReportObservationView",
  "title": "DiagnosticReport → observation (FHIR-flat, stage 1)",
  "status": "draft",
  "experimental": true,
  "description": "When a DiagnosticReport's LOINC code resolves to an OMOP concept with domain_id = Observation, the report produces one or more observation rows. This applies primarily to clinical document types -- history and physical notes, discharge summaries, evaluation and plan notes, consultation notes -- where the LOINC code represents a document class rather than a quantitative measurement or procedure. Each conclusionCode entry generates a separate row. This is the most frequently hit domain for DiagnosticReport resources in real-world EHR data (clinical notes are far more common than lab panel-level reports).\n\nStage 1 of FHIR→OMOP: produce a flat row keeping source codes per vocabulary. Stage 2 joins vocab.concept to resolve concept_ids.",
  "extension": [
    {
      "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table",
      "valueString": "observation"
    },
    {
      "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",
      "valueString": "DiagnosticReport__observation"
    }
  ],
  "resource": "DiagnosticReport",
  "select": [
    {
      "column": [
        {
          "name": "id",
          "path": "DiagnosticReport.id",
          "type": "id",
          "description": "FHIR DiagnosticReport.id; surrogate OMOP key derived (hash/sequence) downstream.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "observation_id"
                },
                {
                  "url": "transform",
                  "valueString": "surrogate key from hash/sequence/lookup of FHIR id"
                }
              ]
            }
          ]
        },
        {
          "name": "code_loinc",
          "path": "DiagnosticReport.code.coding.where(system='http://loinc.org').first().code",
          "type": "code",
          "description": "Report code — LOINC",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "observation_concept_id"
                },
                {
                  "url": "transform",
                  "valueString": "lookup vocab.concept WHERE vocabulary_id='LOINC' AND concept_code = (this column); standard_concept='S' preferred"
                }
              ]
            }
          ]
        },
        {
          "name": "code_snomed",
          "path": "DiagnosticReport.code.coding.where(system='http://snomed.info/sct').first().code",
          "type": "code",
          "description": "Report code — SNOMED",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "observation_concept_id"
                },
                {
                  "url": "transform",
                  "valueString": "lookup vocab.concept WHERE vocabulary_id='SNOMED' AND concept_code = (this column); standard_concept='S' preferred"
                }
              ]
            }
          ]
        },
        {
          "name": "code_text",
          "path": "DiagnosticReport.code.text",
          "type": "string",
          "description": "Free text label from DiagnosticReport.code",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "observation_source_value"
                },
                {
                  "url": "transform",
                  "valueString": "copy text verbatim into OMOP source_value column"
                }
              ]
            }
          ]
        },
        {
          "name": "subject_id",
          "path": "DiagnosticReport.subject",
          "type": "Reference(Patient)",
          "description": "Resolve Patient/{id} reference to integer person_id. Skip row if unresolvable.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "person_id"
                },
                {
                  "url": "transform",
                  "valueString": "resolve PERSON reference; downstream maps to person_id"
                }
              ]
            }
          ]
        },
        {
          "name": "observation_date",
          "path": "DiagnosticReport.effective[x]",
          "type": "dateTime|Period",
          "description": "Date component of effectiveDateTime, or effectivePeriod.start. Skip row if absent (ETL-German behavior).",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "observation_date"
                }
              ]
            }
          ]
        },
        {
          "name": "observation_datetime",
          "path": "DiagnosticReport.effective[x]",
          "type": "dateTime|Period",
          "description": "Full timestamp from effectiveDateTime or effectivePeriod.start.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "observation_datetime"
                }
              ]
            }
          ]
        },
        {
          "name": "value_as_string",
          "path": "DiagnosticReport.conclusionCode.coding[0].display",
          "type": "string",
          "description": "ETL-German stores the SNOMED code string here (line 409). Recommended: use conclusionCode display text, or fall back to conclusion free text (truncated to 60 chars).",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "value_as_string"
                }
              ]
            }
          ]
        },
        {
          "name": "value_as",
          "path": "DiagnosticReport.conclusionCode",
          "type": "CodeableConcept",
          "description": "SNOMED conclusion code resolved to OMOP concept. ETL-German currently stores this in observation_source_concept_id instead. Recommended: store the resolved SNOMED concept here as the clinical value of the report.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "value_as_concept_id"
                },
                {
                  "url": "transform",
                  "valueString": "resolve CONCEPT reference; downstream maps to value_as_concept_id"
                }
              ]
            }
          ]
        },
        {
          "name": "performer_id",
          "path": "DiagnosticReport.performer[0]",
          "type": "Reference(Practitioner)",
          "description": "First performer reference resolved to provider_id. Also consider resultsInterpreter[0].",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "provider_id"
                },
                {
                  "url": "transform",
                  "valueString": "resolve PROVIDER reference; downstream maps to provider_id"
                }
              ]
            }
          ]
        },
        {
          "name": "encounter_id",
          "path": "DiagnosticReport.encounter",
          "type": "Reference(Encounter)",
          "description": "Resolve Encounter/{id} to visit_occurrence_id.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "visit_occurrence_id"
                },
                {
                  "url": "transform",
                  "valueString": "resolve VISIT_OCCURRENCE reference; downstream maps to visit_occurrence_id"
                }
              ]
            }
          ]
        },
        {
          "name": "value_text",
          "path": "DiagnosticReport.conclusionCode.coding[0].code",
          "type": "code",
          "description": "Verbatim SNOMED code. ETL-German does not explicitly set this field. Recommended: store the raw conclusionCode string.",
          "extension": [
            {
              "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-column-target",
              "extension": [
                {
                  "url": "column",
                  "valueString": "value_source_value"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
