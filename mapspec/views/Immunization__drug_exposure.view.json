{
  "resourceType": "ViewDefinition",
  "id": "omop-immunization-drug-exposure",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-immunization-drug-exposure",
  "name": "OmopImmunizationDrugExposureView",
  "title": "Immunization → drug_exposure (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "drug_exposure" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "Immunization__drug_exposure" }
  ],
  "resource": "Immunization",
  "description": "Point-in-time vaccination → drug_exposure row. CVX preferred (standard OMOP Drug); start_date = end_date.",
  "constant": [
    { "name": "cvxSystem",    "valueString": "http://hl7.org/fhir/sid/cvx" },
    { "name": "rxnormSystem", "valueString": "http://www.nlm.nih.gov/research/umls/rxnorm" }
  ],
  "select": [
    {
      "column": [
        { "name": "id",            "path": "id",                                                                "type": "id",       "description": "FHIR Immunization.id → hash → drug_exposure_id." },
        { "name": "subject_ref",   "path": "patient.getReferenceKey()",                                          "type": "string",   "description": "Patient → person_id." },
        { "name": "encounter_ref", "path": "encounter.getReferenceKey()",                                        "type": "string",   "description": "Encounter → visit_occurrence_id." },
        { "name": "code_cvx",      "path": "vaccineCode.coding.where(system=%cvxSystem).code.first()",           "type": "code",     "description": "CVX vaccine code." },
        { "name": "code_rxnorm",   "path": "vaccineCode.coding.where(system=%rxnormSystem).code.first()",        "type": "code",     "description": "RxNorm fallback." },
        { "name": "code_text",     "path": "vaccineCode.text",                                                   "type": "string",   "description": "Vaccine display name." },
        { "name": "occurrence_dt", "path": "occurrence.ofType(dateTime)",                                        "type": "dateTime", "description": "When the immunization happened." },
        { "name": "status_code",   "path": "status",                                                             "type": "code",     "description": "completed / entered-in-error / not-done." }
      ]
    }
  ]
}
