{
  "resourceType": "ViewDefinition",
  "id": "omop-medicationdispense-drug-exposure",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-medicationdispense-drug-exposure",
  "name": "OmopMedicationDispenseDrugExposureView",
  "title": "MedicationDispense → drug_exposure (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "drug_exposure" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "MedicationDispense__drug_exposure" }
  ],
  "resource": "MedicationDispense",
  "description": "Pharmacist's dispense event → drug_exposure row. drug_type_concept_id 38000176.",
  "constant": [
    { "name": "rxnormSystem", "valueString": "http://www.nlm.nih.gov/research/umls/rxnorm" },
    { "name": "ndcSystem",    "valueString": "http://hl7.org/fhir/sid/ndc" }
  ],
  "select": [
    {
      "column": [
        { "name": "id",             "path": "id",                                                                                "type": "id" },
        { "name": "subject_ref",    "path": "subject.getReferenceKey()",                                                          "type": "string" },
        { "name": "encounter_ref",  "path": "context.getReferenceKey()",                                                          "type": "string" },
        { "name": "drug_rxnorm",    "path": "medication.ofType(CodeableConcept).coding.where(system=%rxnormSystem).code.first()", "type": "code" },
        { "name": "drug_ndc",       "path": "medication.ofType(CodeableConcept).coding.where(system=%ndcSystem).code.first()",    "type": "code" },
        { "name": "dispense_dt",    "path": "whenHandedOver",                                                                     "type": "dateTime" },
        { "name": "quantity_value", "path": "quantity.value",                                                                     "type": "decimal" },
        { "name": "days_supply",    "path": "daysSupply.value",                                                                   "type": "integer" }
      ]
    }
  ]
}
