{
  "resourceType": "ViewDefinition",
  "id": "omop-practitionerrole-provider",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-practitionerrole-provider",
  "name": "OmopPractitionerRoleProviderView",
  "title": "PractitionerRole → provider (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "provider" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "PractitionerRole__provider" }
  ],
  "resource": "PractitionerRole",
  "description": "PractitionerRole adds role + specialty + care_site link to an existing Practitioner→provider row. Updates cdm.provider.specialty_concept_id and care_site_id in-place via UPDATE.",
  "constant": [
    { "name": "snomedSystem", "valueString": "http://snomed.info/sct" }
  ],
  "select": [
    {
      "column": [
        { "name": "practitioner_ref", "path": "practitioner.getReferenceKey()", "type": "string" },
        { "name": "org_ref",          "path": "organization.getReferenceKey()", "type": "string" },
        { "name": "specialty_code",   "path": "specialty.first().coding.where(system=%snomedSystem).code.first()", "type": "code" }
      ]
    }
  ]
}
