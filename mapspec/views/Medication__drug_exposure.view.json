{
  "resourceType": "ViewDefinition",
  "id": "omop-medication-drug-exposure",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-medication-drug-exposure",
  "name": "OmopMedicationDrugExposureView",
  "title": "Medication → drug_exposure (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "drug_exposure" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "Medication__drug_exposure" }
  ],
  "resource": "Medication",
  "description": "Standalone Medication resource — drug definition without a patient. Usually NOT mapped to drug_exposure directly; flattened here for completeness so downstream can pick it up if a custom patient link exists.",
  "constant": [
    { "name": "rxnormSystem", "valueString": "http://www.nlm.nih.gov/research/umls/rxnorm" },
    { "name": "ndcSystem",    "valueString": "http://hl7.org/fhir/sid/ndc" }
  ],
  "select": [
    {
      "column": [
        { "name": "id",          "path": "id",                                                  "type": "id" },
        { "name": "drug_rxnorm", "path": "code.coding.where(system=%rxnormSystem).code.first()", "type": "code" },
        { "name": "drug_ndc",    "path": "code.coding.where(system=%ndcSystem).code.first()",    "type": "code" },
        { "name": "code_text",   "path": "code.text",                                            "type": "string" }
      ]
    }
  ]
}
