{
  "resourceType": "ViewDefinition",
  "id": "omop-diagnosticreport-note",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-diagnosticreport-note",
  "name": "OmopDiagnosticReportNoteView",
  "title": "DiagnosticReport → note (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "note" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "DiagnosticReport__note" }
  ],
  "resource": "DiagnosticReport",
  "description": "DiagnosticReport.presentedForm.data (base64) or conclusion → cdm.note. One DR with at least one of those → one note row.",
  "constant": [
    { "name": "loincSystem", "valueString": "http://loinc.org" }
  ],
  "select": [
    {
      "column": [
        { "name": "id",            "path": "id",                                                  "type": "id",       "description": "DR.id → hash → note_id." },
        { "name": "subject_ref",   "path": "subject.getReferenceKey()",                            "type": "string",   "description": "Patient → person_id." },
        { "name": "encounter_ref", "path": "encounter.getReferenceKey()",                          "type": "string",   "description": "Encounter → visit_occurrence_id." },
        { "name": "performer_ref", "path": "performer.first().getReferenceKey()",                  "type": "string",   "description": "First performer → provider_id." },
        { "name": "code_loinc",    "path": "code.coding.where(system=%loincSystem).code.first()",  "type": "code",     "description": "LOINC document/note type → note_class_concept_id." },
        { "name": "code_text",     "path": "code.text",                                            "type": "string",   "description": "Title." },
        { "name": "effective_dt",  "path": "effective.ofType(dateTime)",                           "type": "dateTime", "description": "effectiveDateTime → note_date / _datetime." },
        { "name": "presented_data","path": "presentedForm.first().data",                           "type": "base64Binary", "description": "Base64-encoded note body (Synthea writes plain-text reports here)." },
        { "name": "conclusion",    "path": "conclusion",                                           "type": "string",   "description": "Free-text conclusion (fallback when no presentedForm)." }
      ]
    }
  ]
}
