{
  "resourceType": "ViewDefinition",
  "id": "omop-organization-care-site",
  "url": "https://fhir2omop.health-samurai.io/ViewDefinition/omop-organization-care-site",
  "name": "OmopOrganizationCareSiteView",
  "title": "Organization → care_site (FHIR-flat, stage 1)",
  "version": "0.3.0",
  "status": "draft",
  "experimental": true,
  "extension": [
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-target-table", "valueString": "care_site" },
    { "url": "https://fhir2omop.health-samurai.io/StructureDefinition/omop-edge",        "valueString": "Organization__care_site" }
  ],
  "resource": "Organization",
  "description": "Stage 1: one row per Organization. care_site_source_value = Organization.id (UUID) so that Encounter.serviceProvider.reference (which contains the Org UUID after `|` in Synthea) can be resolved by stage 2.",
  "select": [
    {
      "column": [
        {
          "name": "id",
          "path": "Organization.id",
          "type": "id",
          "description": "Synthea UUID. → care_site_source_value (encounters reference this)."
        },
        {
          "name": "name",
          "path": "Organization.name",
          "type": "string",
          "description": "→ care_site_name."
        },
        {
          "name": "type_code",
          "path": "Organization.type.first().coding.first().code",
          "type": "code",
          "description": "HL7 organization-type (prov/dept/team/govt/edu/…). → place_of_service_concept_id via small inline lookup."
        }
      ]
    }
  ]
}
