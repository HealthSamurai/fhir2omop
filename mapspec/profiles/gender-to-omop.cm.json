{
  "resourceType": "ConceptMap",
  "id": "gender-to-omop",
  "url": "https://fhir2omop.health-samurai.io/ConceptMap/gender-to-omop",
  "version": "0.1.0",
  "name": "GenderToOmop",
  "title": "FHIR gender (administrative-gender + us-core-birthsex) → OMOP gender_concept_id",
  "status": "active",
  "experimental": true,
  "description": "Two-group ConceptMap covering both FHIR Patient.gender (administrative-gender ValueSet) and the US Core birthsex extension (HL7 v3 AdministrativeGender). Stage-2 SQL prefers birthsex (closer to OMOP biological sex semantics) and falls back to Patient.gender.",
  "targetUri": "https://athena.ohdsi.org/search-terms/terms?domain=Gender&vocabulary=Gender",
  "group": [
    {
      "source": "http://hl7.org/fhir/administrative-gender",
      "target": "https://athena.ohdsi.org/search-terms/terms?domain=Gender",
      "element": [
        { "code": "male",    "display": "Male",    "target": [{ "code": "8507", "display": "MALE",    "equivalence": "equivalent" }] },
        { "code": "female",  "display": "Female",  "target": [{ "code": "8532", "display": "FEMALE",  "equivalence": "equivalent" }] },
        { "code": "other",   "display": "Other",   "target": [{ "code": "8521", "display": "OTHER",   "equivalence": "equivalent" }] },
        { "code": "unknown", "display": "Unknown", "target": [{ "code": "8551", "display": "UNKNOWN", "equivalence": "equivalent" }] }
      ]
    },
    {
      "source": "http://terminology.hl7.org/CodeSystem/v3-AdministrativeGender",
      "target": "https://athena.ohdsi.org/search-terms/terms?domain=Gender",
      "element": [
        { "code": "M",   "display": "Male",    "target": [{ "code": "8507", "display": "MALE",    "equivalence": "equivalent" }] },
        { "code": "F",   "display": "Female",  "target": [{ "code": "8532", "display": "FEMALE",  "equivalence": "equivalent" }] },
        { "code": "OTH", "display": "Other",   "target": [{ "code": "8521", "display": "OTHER",   "equivalence": "equivalent" }] },
        { "code": "UNK", "display": "Unknown", "target": [{ "code": "8551", "display": "UNKNOWN", "equivalence": "equivalent" }] }
      ]
    }
  ]
}
