        { "code": "2076-8", "display": "Native Hawaiian or Other Pacific Islander",   "target": [{ "code": "8557", "display": "Native Hawaiian or Other Pacific Islander",   "equivalence": "equivalent" }] },
        { "code": "UNK",    "display": "Unknown",                                     "target": [{ "code": "8552", "display": "Unknown",                                     "equivalence": "equivalent" }] }
