{
  "$schema": "../schema/edge.schema.json",
  "fhir_resource": "Condition",
  "omop_table": "measurement",
  "direction": "fhir-to-omop",
  "status": "implemented",
  "primary": false,
  "required": false,
  "condition": "Condition.code.coding Maps to a standard concept with domain_id='Measurement'.",
  "narrative_md": "Sibling of `Condition__condition_occurrence`. Some SNOMED codes that the source modeled as a Condition resolve to a Measurement-domain standard concept; this edge routes them to `cdm_ours_fhir.measurement` rather than dropping them.",
  "fields": [
    { "omop_column": "measurement_id",            "fhir_path": "Condition.id || '|' || std_concept_id (hashed)", "fhir_type": "id", "omop_type": "integer", "required": true, "pk": true },
    { "omop_column": "person_id",                 "fhir_path": "Condition.subject", "fhir_type": "Reference(Patient)", "omop_type": "integer", "required": true, "fk": "PERSON" },
    { "omop_column": "measurement_concept_id",    "fhir_path": "Condition.code.coding (any) → Maps to → standard (domain=Measurement)", "fhir_type": "CodeableConcept", "omop_type": "integer", "required": true, "fk": "CONCEPT" },
    { "omop_column": "measurement_date",          "fhir_path": "Condition.onset[x] | Condition.recordedDate", "fhir_type": "dateTime", "omop_type": "date" },
    { "omop_column": "measurement_type_concept_id","fhir_path": "(constant)", "fhir_type": "code", "omop_type": "integer", "constant": 32827 },
    { "omop_column": "measurement_source_value",  "fhir_path": "Condition.code.coding.display | code | text", "fhir_type": "string", "omop_type": "varchar(50)" },
    { "omop_column": "measurement_source_concept_id","fhir_path": "vocab.concept(coding.system, coding.code)", "fhir_type": "code", "omop_type": "integer", "fk": "CONCEPT" }
  ]
}
