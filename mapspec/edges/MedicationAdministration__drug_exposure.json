  "edge_cases": [
    {
      "case": "status = entered-in-error",
      "handling": "Skip -- do not create drug_exposure row.",
      "implementations": ["ETL-German", "fhir-to-omop-demo", "consensus"]
    },
    {
      "case": "status = not-done",
      "handling": "Skip -- medication was not administered."
    },
    {
      "case": "status = stopped",
      "handling": "Implementation-dependent. ETL-German maps; this project would skip."
    },
    {
      "case": "effectiveDateTime (point in time)",
      "handling": "Start and end date are the same. omoponfhir general rule: setDrugExposureStartDate(date); setDrugExposureEndDate(date).",
      "implementations": ["omoponfhir", "ETL-German", "fhir-to-omop-demo"]
    },
    {
      "case": "effectivePeriod with start but no end",
      "handling": "End date = start date."
    },
    {
      "case": "dosage absent",
      "handling": "Leave quantity, route_concept_id, route_source_value, dose_unit_source_value, sig all null."
    },
    {
      "case": "doseRange (Range instead of Quantity)",
      "handling": "ETL-German computes the mean of low and high. Others leave quantity null.",
      "implementations": ["ETL-German"]
    },
    {
      "case": "Multiple codings in medication[x]",
      "handling": "Best by vocabulary priority (RxNorm > ATC > NDC > first)."
    },
    {
      "case": "No medication code found",
      "handling": "Skip -- consensus across implementations.",
      "implementations": ["ETL-German", "fhir-to-omop-demo", "consensus"]
    }
  ]
