      ]
    },
    {
      "omop_column": "drug_source_value",
      "fhir_path": "MedicationAdministration.medication[x].coding[best].code",
      "fhir_type": "code",
      "omop_type": "varchar(50)",
      "notes": "Best code by vocabulary priority (RxNorm > ATC > NDC > first). ETL-German uses ATC code.",
      "sources": [
        {
          "comment": "ETL-German specifically picks the ATC coding for European data",
          "references": [
