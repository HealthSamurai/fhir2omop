      "omop_type": "integer",
      "notes": "Not applicable. Refills are MedicationRequest-only. Leave null."
    },
    {
      "omop_column": "quantity",
      "fhir_path": "MedicationAdministration.dosage.dose.value",
      "fhir_type": "decimal",
      "omop_type": "float",
      "notes": "Dose amount given. ETL-German computes mean of Range when doseRange is used.",
      "sources": [
        {
          "comment": "ETL-German computes the arithmetic mean of doseRange.low and doseRange.high when a Range is used instead of a Quantity; other implementations leave quantity null in that case",
          "references": [
            {
              "project": "ETL-German-FHIR-Core",
              "kind": "java",
              "path": "refs/refs/ETL-German-FHIR-Core/src/main/java/org/miracum/etl/fhirtoomop/mapper/MedicationAdministrationMapper.java",
              "notes": "doseRange mean computation"
            }
          ]
        },
        {
          "comment": "fhir-to-omop-demo reads dosage.dose.value directly with no Range handling",
          "references": [
            {
              "project": "fhir-to-omop-demo",
              "kind": "jq",
              "path": "refs/refs/fhir-to-omop-demo/demo/translate/map/MedicationAdministration.jq",
              "notes": "59 lines"
            }
          ]
        }
      ]
    },
    {
      "omop_column": "days_supply",
      "fhir_path": null,
