{
  "$schema": "../schema/edge.schema.json",
  "fhir_resource": "MedicationAdministration",
  "omop_table": "drug_exposure",
  "direction": "fhir-to-omop",
  "status": "documented",
  "primary": true,
  "required": true,
  "narrative_md": "Inpatient medication administration events. Each MedicationAdministration produces one drug_exposure row distinguished by drug_type_concept_id = 38000179 (Physician administered drug). MedicationAdministration carries the richest route and dose-event timing information of the four medication resources.",
  "implementation_in_project": null,
  "fields": [
    {
      "omop_column": "drug_exposure_id",
      "fhir_path": "MedicationAdministration.id",
      "fhir_type": "id",
      "omop_type": "integer",
      "required": true,
      "pk": true,
      "notes": "Surrogate key. Generated deterministically from MedicationAdministration.id."
    },
    {
      "omop_column": "person_id",
      "fhir_path": "MedicationAdministration.subject",
      "fhir_type": "Reference(Patient)",
      "omop_type": "integer",
      "required": true,
      "fk": "PERSON",
      "notes": "Resolved from subject reference to Patient."
    },
    {
      "omop_column": "drug_concept_id",
      "fhir_path": "MedicationAdministration.medication[x]",
      "fhir_type": "CodeableConcept/Reference(Medication)",
      "omop_type": "integer",
      "required": true,
      "fk": "CONCEPT",
      "notes": "RxNorm / ATC / NDC mapped to OMOP standard concept. medicationCodeableConcept resolved inline; medicationReference resolved via Medication resource lookup. Placeholder: 0 when concept lookup unavailable.",
      "sources": [
        {
          "comment": "ETL-German pre-indexes Medication resources via medication_id_map, then extracts ATC code for EU data",
          "references": [
            {
              "project": "ETL-German-FHIR-Core",
              "kind": "java",
              "path": "refs/refs/ETL-German-FHIR-Core/src/main/java/org/miracum/etl/fhirtoomop/mapper/MedicationMapper.java",
              "notes": "274 lines — ATC code extraction and concept lookup"
            },
            {
              "project": "ETL-German-FHIR-Core",
              "kind": "java",
              "path": "refs/refs/ETL-German-FHIR-Core/src/main/java/org/miracum/etl/fhirtoomop/mapper/MedicationAdministrationMapper.java",
              "notes": "Resolves references via pre-indexed medication_id_map"
            }
          ]
        },
        {
          "comment": "fhir-to-omop-demo processes inline medicationCodeableConcept only; medicationReference requires external merge phase not implemented for MedicationAdministration",
          "references": [
            {
              "project": "fhir-to-omop-demo",
              "kind": "jq",
              "path": "refs/refs/fhir-to-omop-demo/demo/translate/map/MedicationAdministration.jq",
              "notes": "59 lines"
            }
          ]
        }
      ]
    },
    {
      "omop_column": "drug_exposure_start_date",
      "fhir_path": "MedicationAdministration.effectiveDateTime | MedicationAdministration.effectivePeriod.start",
      "fhir_type": "dateTime",
      "omop_type": "date",
      "required": true,
      "notes": "Point-in-time (effectiveDateTime) or period start. Resource skipped if neither is available."
    },
    {
      "omop_column": "drug_exposure_start_datetime",
      "fhir_path": "MedicationAdministration.effectiveDateTime | MedicationAdministration.effectivePeriod.start",
      "fhir_type": "dateTime",
      "omop_type": "datetime",
      "notes": "Full ISO datetime."
    },
    {
      "omop_column": "drug_exposure_end_date",
      "fhir_path": "MedicationAdministration.effectivePeriod.end",
      "fhir_type": "dateTime",
      "omop_type": "date",
      "required": true,
      "transform": "effectivePeriod.end ?? drug_exposure_start_date",
      "notes": "When effectiveDateTime is used (single point), end = start. When effectivePeriod has no end, end = start. omoponfhir general rule: setDrugExposureEndDate(startDate) when no period end.",
      "sources": [
        {
          "comment": "omoponfhir, ETL-German, and fhir-to-omop-demo all set end = start when effectiveDateTime (point in time) is used or period has no end",
          "references": [
            {
              "project": "ETL-German-FHIR-Core",
              "kind": "java",
              "path": "refs/refs/ETL-German-FHIR-Core/src/main/java/org/miracum/etl/fhirtoomop/mapper/MedicationAdministrationMapper.java",
              "notes": "Copies start date when no period end available"
            },
            {
              "project": "fhir-to-omop-demo",
              "kind": "jq",
              "path": "refs/refs/fhir-to-omop-demo/demo/translate/map/MedicationAdministration.jq",
              "notes": "59 lines"
            }
          ]
        }
      ]
    },
    {
      "omop_column": "drug_exposure_end_datetime",
      "fhir_path": "MedicationAdministration.effectivePeriod.end",
      "fhir_type": "dateTime",
      "omop_type": "datetime",
      "notes": "Full ISO datetime. Null if no period end."
    },
    {
      "omop_column": "verbatim_end_date",
      "fhir_path": null,
      "fhir_type": null,
      "omop_type": "date",
      "notes": "Most implementations leave null. No direct FHIR source for MedicationAdministration."
    },
    {
      "omop_column": "drug_type_concept_id",
      "fhir_path": null,
      "fhir_type": null,
      "omop_type": "integer",
      "required": true,
      "fk": "CONCEPT",
      "constant": 38000179,
      "concept_map": "drug_type",
      "notes": "38000179 = 'Physician administered drug (identified as procedure)'. fhir-to-omop-demo uses 32818 (EHR administration record). FhirToCdm/ETL-German use 32817 (EHR/CLAIM).",
      "sources": [
        {
          "comment": "This project and consensus use 38000179 (Physician administered drug) as the most semantically precise type for MedicationAdministration",
          "references": []
        },
        {
          "comment": "fhir-to-omop-demo uses 32818 (EHR administration record) — a more generic EHR-record type",
          "references": [
            {
              "project": "fhir-to-omop-demo",
              "kind": "jq",
              "path": "refs/refs/fhir-to-omop-demo/demo/translate/map/MedicationAdministration.jq",
              "lines": [39, 39],
              "notes": "drug_type_concept_id = 32818 at line 39"
            }
          ]
        },
        {
          "comment": "FhirToCdm and ETL-German use 32817 (EHR/CLAIM) universally across all medication resource types",
          "references": [
            {
              "project": "ETL-German-FHIR-Core",
              "kind": "java",
              "path": "refs/refs/ETL-German-FHIR-Core/src/main/java/org/miracum/etl/fhirtoomop/mapper/MedicationAdministrationMapper.java",
              "notes": "Uses CONCEPT_CLAIM (32817) for all medication resources"
            }
          ]
        }
      ]
    },
    {
      "omop_column": "stop_reason",
      "fhir_path": null,
      "fhir_type": null,
      "omop_type": "varchar(20)",
      "notes": "MedicationAdministration does not commonly carry a discontinuation reason. Leave null."
    },
    {
      "omop_column": "refills",
      "fhir_path": null,
