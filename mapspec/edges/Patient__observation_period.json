  "edge_cases": [
    {
      "case": "Person has zero events",
      "handling": "Skip the row (Strategy B) or use fixed window (Strategy A). Strategy B is preferred for production use."
    },
    {
      "case": "Person is deceased",
      "handling": "observation_period_end_date = min(latest_event, death_date). Do not extend past death."
    },
    {
      "case": "Multiple disjoint observation windows",
      "handling": "OMOP supports multiple rows per person. Use a gap parameter (e.g. 30 days) to merge adjacent periods or leave as separate rows."
    },
    {
      "case": "Incremental loads",
      "handling": "Re-derive end dates after each batch; rewrite affected observation_period rows for persons with new events."
    },
    {
      "case": "Strategy A (fixed 1900-2100) is incorrect for production",
      "handling": "Makes cohort definitions meaningless because every person appears observable for 200 years. Use Strategy B (min/max over events) for any analytic use.",
      "implementations": [
        "NACHC"
      ]
    },
    {
      "case": "omoponfhir, fhir-to-omop-demo, and fhir-x-omop skip this table",
      "handling": "Cohort tooling treats these persons as having zero observable time, effectively excluding them from all OHDSI analyses."
    }
  ]
