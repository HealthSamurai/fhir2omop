  "edge_cases": [
    {
      "case": "valueString present",
      "handling": "Maps directly to value_as_string.",
      "implementations": [
        "this project",
        "HL7 IG FML",
        "fhir-to-omop-demo"
      ]
    },
    {
      "case": "valueCodeableConcept with no matching OMOP concept",
      "handling": "value_as_concept_id=null. Text goes to value_as_string."
    },
    {
      "case": "valueBoolean",
      "handling": "Not mapped. Could use value_as_string='true'/'false' or concept IDs 4188539/4188540."
    },
    {
      "case": "interpretation with multiple codings",
      "handling": "Only first coding used for qualifier_source_value."
    },
    {
      "case": "Status not in {final, amended, corrected}",
      "handling": "Skip entire observation."
    },
    {
      "case": "Missing effectiveDateTime",
      "handling": "Skip -- observation_date is required."
    },
    {
      "case": "effectivePeriod instead of dateTime",
      "handling": "Use period.start."
    },
    {
      "case": "Categories not in routing set (exam, imaging, therapy)",
      "handling": "Route to measurement (default). HL7 IG routes these to observation."
    },
    {
      "case": "LOINC code with Observation domain but lab category",
      "handling": "Category wins (routes to measurement). ETL-German: domain wins."
    }
  ]
}
