      "fhir_path": "Condition.id",
      "fhir_type": "id",
      "omop_type": "integer",
      "required": true,
      "pk": true,
      "notes": "Surrogate key generated from Condition.id. Hash/sequence/lookup. HL7 IG FML has this commented out (line 11)."
    },
    {
      "omop_column": "person_id",
      "fhir_path": "Condition.subject",
      "fhir_type": "Reference(Patient)",
      "omop_type": "integer",
