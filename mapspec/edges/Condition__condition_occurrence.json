  "edge_cases": [
    {
      "case": "Missing onset[x] + missing recordedDate",
      "handling": "Skip -- no valid start date. condition_start_date is required in OMOP.",
      "implementations": ["ETL-German logs via noStartDateCounter", "omoponfhir uses 9999-12-31 sentinel instead of skipping"]
    },
    {
      "case": "onsetAge (e.g. 45 years)",
      "handling": "Not mapped by most. Requires patient birthDate for calculation.",
      "implementations": ["ETL-German calculates birthDate + age via ResourceOnset helper"]
    },
    {
      "case": "onsetPeriod with start and end",
      "handling": "start -> condition_start_date, end -> condition_end_date.",
      "implementations": ["omoponfhir maps Period.end to condition_end_date", "This project maps Period.start only (not Period.end)"]
    },
    {
      "case": "Multiple code.coding entries (e.g. ICD-10 + SNOMED)",
      "handling": "Select best coding by vocabulary priority (SNOMED > ICD-10-CM > ICD-10 > CPT-4).",
      "implementations": ["ETL-German generates separate rows per coding system", "FhirToCdm iterates all codings", "This project picks best only"]
    },
    {
      "case": "severity present",
      "handling": "Dropped by most implementations.",
      "implementations": ["ETL-German creates separate observation record with qualifier_concept_id = CONCEPT_SEVERITY"]
    },
    {
      "case": "bodySite present",
      "handling": "Dropped by most implementations.",
      "implementations": ["ETL-German creates separate observation record with qualifier_concept_id = CONCEPT_FINDING_SITE"]
    },
    {
      "case": "stage present",
      "handling": "Dropped by most implementations.",
      "implementations": ["ETL-German creates separate observation record with qualifier_concept_id = CONCEPT_STAGE"]
    },
    {
      "case": "verificationStatus = provisional",
      "handling": "Mapped. Some implementations skip non-confirmed; this project maps provisional.",
      "implementations": ["ETL-German has explicit acceptable status list"]
    },
    {
      "case": "verificationStatus = entered-in-error",
      "handling": "Skip always. Universal consensus across implementations."
    },
    {
      "case": "SNOMED code with domain_id != Condition",
      "handling": "Should route to observation/procedure/measurement. Requires vocabulary DB.",
      "implementations": ["Only ETL-German routes (lines 921-988)", "All others route everything to condition_occurrence"]
    },
    {
      "case": "abatementString longer than 20 chars",
      "handling": "Truncated to fit stop_reason varchar(20).",
      "implementations": ["This project truncates via .substring(0, 20)"]
    },
    {
      "case": "Missing Condition.code",
      "handling": "Skip -- no concept to map.",
      "implementations": ["This project returns null", "ETL-German increments noCodeCounter"]
    },
    {
      "case": "Missing Condition.subject",
      "handling": "Skip or error.",
      "implementations": ["This project defaults person_id to 0", "omoponfhir throws FHIRException"]
    },
    {
      "case": "ICD-10-GM primary + secondary codes",
      "handling": "Split into separate condition_occurrence rows.",
      "implementations": ["ETL-German-specific: splits codes with spaces into primary/secondary"]
    },
    {
      "case": "Diagnostic confidence (ICD-10-GM extension)",
      "handling": "Maps to condition_status_concept_id.",
      "implementations": ["ETL-German-specific: extracts from ICD coding extension"]
    }
  ]
