{
  "$schema": "../schema/edge.schema.json",
  "fhir_resource": "Coverage",
  "omop_table": "payer_plan_period",
  "direction": "fhir-to-omop",
  "status": "documented",
  "primary": true,
  "required": true,
  "condition": "Coverage.status = 'active'",
  "narrative_md": "FHIR Coverage captures a patient's insurance enrollment (payer, plan, coverage period, subscriber relationship). It maps to OMOP payer_plan_period, which records continuous enrollment under a specific health benefit plan from a given payer. Unlike clinical event tables, payer_plan_period carries no _type_concept_id; it is purely administrative. One active Coverage resource produces one payer_plan_period row. Overlapping or adjacent periods for the same person/payer may be collapsed.",
  "implementation_in_project": null,
  "fields": [
    {
      "omop_column": "payer_plan_period_id",
      "fhir_path": "Coverage.id",
      "fhir_type": "id",
      "omop_type": "integer",
      "required": true,
      "pk": true,
      "notes": "Surrogate key. Generated via hash/sequence/lookup of Coverage.id."
    },
    {
      "omop_column": "person_id",
      "fhir_path": "Coverage.beneficiary",
      "fhir_type": "Reference(Patient)",
      "omop_type": "integer",
      "required": true,
      "fk": "PERSON",
      "notes": "Resolve Patient reference to integer person_id via the same ID mapping used by the Patient mapper."
    },
    {
      "omop_column": "payer_plan_period_start_date",
      "fhir_path": "Coverage.period.start",
      "fhir_type": "dateTime",
      "omop_type": "date",
      "required": true,
      "notes": "Coverage start date. If absent, use ETL epoch or earliest known date. NOT NULL in OMOP.",
      "sources": [
        {
          "comment": "MIN(billablePeriod.start) grouped by patient+insurer (derived from EOB, not Coverage directly)",
          "references": [
            { "project": "avalon-fhir-omop", "kind": "sql", "path": "refs/refs/avalon-fhir-omop/omop-views/models/omop_payer_plan_period.sql", "lines": [30, 51] }
          ]
        },
        {
          "comment": "period.start from Coverage (reverse direction: OMOP→FHIR, from payer_plan_period_start_date)",
          "references": [
            { "project": "mends-on-fhir", "kind": "whistle", "path": "refs/refs/mends-on-fhir/whistle-mappings/synthea/whistle-functions/zzPPP_CoverageImpl.wstl", "lines": [34, 35] }
          ]
        }
      ]
    },
    {
      "omop_column": "payer_plan_period_end_date",
      "fhir_path": "Coverage.period.end",
      "fhir_type": "dateTime",
      "omop_type": "date",
      "required": true,
      "notes": "Coverage end date. If absent or open-ended, use 9999-12-31 or ETL end date. NOT NULL in OMOP.",
      "sources": [
        {
          "comment": "MAX(COALESCE(billablePeriod.end, billablePeriod.start)) — uses start as fallback when end is absent",
          "references": [
            { "project": "avalon-fhir-omop", "kind": "sql", "path": "refs/refs/avalon-fhir-omop/omop-views/models/omop_payer_plan_period.sql", "lines": [30, 51] }
          ]
        },
        {
          "comment": "period.end from Coverage (reverse direction: OMOP→FHIR)",
          "references": [
            { "project": "mends-on-fhir", "kind": "whistle", "path": "refs/refs/mends-on-fhir/whistle-mappings/synthea/whistle-functions/zzPPP_CoverageImpl.wstl", "lines": [34, 35] }
          ]
        }
      ]
    },
    {
      "omop_column": "payer_concept_id",
      "fhir_path": "Coverage.payor[0]",
      "fhir_type": "Reference(Organization|Patient|RelatedPerson)",
      "omop_type": "integer",
      "required": false,
      "fk": "CONCEPT",
      "concept_map": "payer",
      "transform": "resolve payor[0] -> Organization.name -> OMOP Payer vocabulary lookup",
      "notes": "OMOP Payer vocabulary concept (vocabulary_id='Payer', domain_id='Payer'). Resolve Organization reference, map name to payer concept. Default: 0. If payor references Patient (self-pay), use concept_id 436.",
      "sources": [
        {
          "comment": "Mapped via 130-entry ConceptMap (OMOP payer_concept_id ↔ FHIR v3-ActCode) — reverse direction (OMOP→FHIR)",
          "references": [
            { "project": "mends-on-fhir", "kind": "json", "path": "refs/refs/mends-on-fhir/whistle-mappings/synthea/concept-maps/PPP.payor-concept-id--Coverage.type.json" }
          ]
        },
        {
          "comment": "All concept_ids = 0 or NULL (no vocabulary lookup performed)",
          "references": [
            { "project": "avalon-fhir-omop", "kind": "sql", "path": "refs/refs/avalon-fhir-omop/omop-views/models/omop_payer_plan_period.sql", "lines": [35, 47] }
          ]
        }
      ]
    },
    {
      "omop_column": "payer_source_value",
      "fhir_path": "Coverage.payor[0]",
      "fhir_type": "Reference(Organization|Patient|RelatedPerson)",
      "omop_type": "varchar(50)",
      "required": false,
      "transform": "resolve payor[0] -> Organization.name or Reference.display",
      "notes": "Verbatim payer name or identifier. Resolve Organization reference and extract Organization.name. Fallback to Reference.display. Truncate to 50 chars.",
      "sources": [
        {
          "comment": "insurer.display from ExplanationOfBenefit (no Coverage direct mapping)",
          "references": [
            { "project": "avalon-fhir-omop", "kind": "sql", "path": "refs/refs/avalon-fhir-omop/omop-views/models/omop_payer_plan_period.sql", "lines": [8, 28] }
          ]
        },
        {
          "comment": "payor[0].display (from PPP.plan_source_value) — reverse OMOP→FHIR direction",
          "references": [
            { "project": "mends-on-fhir", "kind": "whistle", "path": "refs/refs/mends-on-fhir/whistle-mappings/synthea/whistle-functions/zzPPP_CoverageImpl.wstl", "lines": [51, 51] }
          ]
        }
      ]
    },
    {
      "omop_column": "payer_source_concept_id",
      "fhir_path": null,
      "fhir_type": "integer",
      "omop_type": "integer",
      "required": false,
      "fk": "CONCEPT",
      "constant": 0,
      "notes": "Source concept for the payer if a non-standard vocabulary is used. Default: 0."
    },
    {
      "omop_column": "plan_concept_id",
      "fhir_path": "Coverage.type.coding[0].code",
      "fhir_type": "code",
      "omop_type": "integer",
      "required": false,
      "fk": "CONCEPT",
      "concept_map": "plan_type",
      "transform": "map Coverage.type (v3-ActCode) to OMOP Plan vocabulary",
      "notes": "Map Coverage.type to OMOP Plan vocabulary. No standard OMOP vocabulary maps directly to Coverage.type. Default: 0."
    },
    {
      "omop_column": "plan_source_value",
      "fhir_path": "Coverage.type.text | Coverage.class.where(type.coding.code='plan').name | Coverage.class.where(type.coding.code='plan').value",
      "fhir_type": "string",
      "omop_type": "varchar(50)",
      "required": false,
      "transform": "Use Coverage.type.text, or class entry where type.coding.code='plan'. Concatenate group+plan if both present.",
      "notes": "Plan name as it appears in source. Truncate to 50 chars."
    },
    {
      "omop_column": "plan_source_concept_id",
      "fhir_path": null,
      "fhir_type": "integer",
      "omop_type": "integer",
      "required": false,
      "fk": "CONCEPT",
      "constant": 0,
      "notes": "Source concept for the plan. Default: 0."
    },
    {
      "omop_column": "sponsor_concept_id",
      "fhir_path": "Coverage.policyHolder",
      "fhir_type": "Reference(Organization|Patient|RelatedPerson)",
      "omop_type": "integer",
      "required": false,
      "fk": "CONCEPT",
      "transform": "resolve policyHolder -> Organization.name -> OMOP Sponsor vocabulary lookup",
      "notes": "OMOP Sponsor vocabulary concept. The policyHolder (often the employer) is the sponsor. Default: 0."
    },
    {
      "omop_column": "sponsor_source_value",
      "fhir_path": "Coverage.policyHolder",
      "fhir_type": "Reference(Organization|Patient|RelatedPerson)",
      "omop_type": "varchar(50)",
      "required": false,
      "transform": "resolve policyHolder -> Organization.name or identifier",
      "notes": "Sponsor name from policyHolder reference. Truncate to 50 chars."
    },
    {
      "omop_column": "sponsor_source_concept_id",
      "fhir_path": null,
      "fhir_type": "integer",
      "omop_type": "integer",
      "required": false,
      "fk": "CONCEPT",
      "constant": 0,
      "notes": "Source concept for the sponsor. Default: 0."
    },
    {
      "omop_column": "family_source_value",
      "fhir_path": "Coverage.subscriberId",
      "fhir_type": "string",
      "omop_type": "varchar(50)",
      "required": false,
      "notes": "The subscriber ID links all family members under the same policy. Truncate to 50 chars."
    },
    {
      "omop_column": "stop_reason_concept_id",
      "fhir_path": null,
      "fhir_type": "integer",
      "omop_type": "integer",
      "required": false,
      "fk": "CONCEPT",
      "constant": 0,
      "notes": "FHIR Coverage has no stop reason field. If Coverage.status='cancelled', could use a concept for cancellation. Default: 0."
    },
    {
      "omop_column": "stop_reason_source_value",
      "fhir_path": null,
      "fhir_type": "string",
      "omop_type": "varchar(50)",
      "required": false,
      "notes": "Not directly available from FHIR Coverage. Could store Coverage.status if not 'active'."
    },
    {
      "omop_column": "stop_reason_source_concept_id",
      "fhir_path": null,
      "fhir_type": "integer",
      "omop_type": "integer",
      "required": false,
      "fk": "CONCEPT",
      "constant": 0,
      "notes": "Default: 0."
    }
  ],
