  "edge_cases": [
    {
      "case": "Missing Coverage.period",
      "handling": "Both payer_plan_period_start_date and payer_plan_period_end_date are NOT NULL. Use ETL epoch date for start, 9999-12-31 or current date for end. Log warning."
    },
    {
      "case": "Open-ended period (period.end absent)",
      "handling": "Coverage is still active. Use 9999-12-31 or the ETL run date as payer_plan_period_end_date."
    },
    {
      "case": "period.end < period.start",
      "handling": "Data quality error. Skip the record or swap dates with a warning.",
      "implementations": ["avalon-fhir-omop"]
    },
    {
      "case": "Coverage.status != 'active'",
      "handling": "Skip Coverage resources with status cancelled, draft, or entered-in-error. Do not create a payer_plan_period row."
    },
    {
      "case": "Multiple payor[] entries",
      "handling": "OMOP has a single payer_source_value per row. Options: (a) take the first payor, (b) create one row per payor with the same period, (c) concatenate payor names (truncated to 50 chars)."
    },
    {
      "case": "payor references Patient (self-pay)",
      "handling": "Set payer_source_value = 'Self-pay' or patient name, payer_concept_id = 436."
    },
    {
      "case": "No Organization resource for payor",
      "handling": "Use Reference.display as fallback for payer_source_value. If no display, use the reference string itself."
    },
    {
      "case": "Overlapping Coverage periods (same person, same payer)",
      "handling": "Collapse into a single payer_plan_period row with MIN(start), MAX(end). FhirToCdm does this via CanPayerPlanPeriodBeCombined() -- combines when payer+plan source values match.",
      "implementations": ["FhirToCdm"]
    },
    {
      "case": "Coverage.class[] absent",
      "handling": "No plan details available. plan_source_value = null. Use Coverage.type.text if available."
    },
    {
      "case": "Multiple Coverage resources for same person",
      "handling": "Create one payer_plan_period row per Coverage (per payer/plan/period combination). May collapse adjacent/overlapping periods."
    },
    {
      "case": "subscriberId too long for varchar(50)",
      "handling": "Truncate to 50 characters."
    },
    {
      "case": "Coverage from EOB (no discrete Coverage resource)",
      "handling": "Derive payer_plan_period from ExplanationOfBenefit.billablePeriod + insurer. Group by patient+insurer, MIN/MAX dates.",
      "implementations": ["avalon-fhir-omop"]
    }
  ]
}
