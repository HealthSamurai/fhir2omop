    { "omop_column": "person_id",           "fhir_path": "Condition.subject",                              "fhir_type": "Reference(Patient)", "omop_type": "integer", "required": true, "fk": "PERSON" },
    { "omop_column": "observation_concept_id","fhir_path": "Condition.code.coding (any) → Maps to → standard (domain=Observation)", "fhir_type": "CodeableConcept", "omop_type": "integer", "required": true, "fk": "CONCEPT" },
    { "omop_column": "observation_date",    "fhir_path": "Condition.onset[x] | Condition.recordedDate",    "fhir_type": "dateTime","omop_type": "date" },
    { "omop_column": "observation_type_concept_id","fhir_path": "(constant)",                              "fhir_type": "code",    "omop_type": "integer", "constant": 32827, "notes": "EHR encounter record." },
    { "omop_column": "observation_source_value","fhir_path": "Condition.code.coding.display | code | text","fhir_type": "string", "omop_type": "varchar(50)" },
    { "omop_column": "observation_source_concept_id","fhir_path": "vocab.concept(coding.system, coding.code)","fhir_type": "code","omop_type": "integer", "fk": "CONCEPT" }
  ],
