  "edge_cases": [
    {
      "case": "Multiple bodySite entries",
      "handling": "Take first bodySite[0] for modifier_concept_id. ETL-German filters to SNOMED codings only. Remaining body sites are lost.",
      "implementations": [
        "ETL-German"
      ]
    },
    {
      "case": "Multiple performer entries",
      "handling": "Iterate and take first Practitioner-typed actor for provider_id. Non-Practitioner performers (Organization, Device) are ignored.",
      "implementations": [
        "omoponfhir",
        "ETL-German"
      ]
    },
    {
      "case": "Multiple code.coding entries",
      "handling": "Select best coding by vocabulary priority (SNOMED > CPT > ICD-10-PCS). ETL-German uses OPS > DICOM > SNOMED priority. FhirToCdm creates one row per coding. HL7 IG takes first coding only.",
      "implementations": [
        "ETL-German",
        "FhirToCdm",
        "fhir-omop-ig"
      ]
    },
    {
      "case": "Code with non-Procedure domain",
      "handling": "Route to appropriate OMOP table (drug_exposure, observation, measurement) based on standard concept's domain_id.",
      "implementations": [
        "ETL-German",
        "NACHC",
        "FhirToCdm"
      ]
    },
    {
      "case": "Missing performed[x] (no date)",
      "handling": "Skip resource. procedure_date is required. ETL-German logs warning and returns null.",
      "implementations": [
        "ETL-German"
      ]
    },
    {
      "case": "Missing subject reference",
      "handling": "Skip resource. person_id is required. omoponfhir throws FHIRException. ETL-German logs and returns null.",
      "implementations": [
        "omoponfhir",
        "ETL-German"
      ]
    },
    {
      "case": "Missing code",
      "handling": "Skip resource. procedure_concept_id is required (0 is acceptable). ETL-German logs and skips.",
      "implementations": [
        "ETL-German"
      ]
    },
    {
      "case": "status = entered-in-error",
      "handling": "Skip resource. For incremental loads, delete any previously mapped record.",
      "implementations": [
        "ETL-German"
      ]
    },
    {
      "case": "Extremely long procedure_source_value",
      "handling": "OMOP field is varchar(50). Truncate code string to 50 characters. No implementation explicitly handles this."
    },
    {
      "case": "usedCode (device codes) present",
      "handling": "ETL-German creates device_exposure rows from Procedure.usedCode codings. Other implementations ignore this field.",
      "implementations": [
        "ETL-German"
      ]
    },
    {
      "case": "focalDevice present",
      "handling": "Could create device_exposure row. ETL-German handles usedCode (not focalDevice) for device exposure. No standard mapping for focalDevice."
    },
    {
      "case": "reasonReference to Condition",
      "handling": "Could populate fact_relationship to link procedure and condition. Not implemented in any reference."
    },
    {
      "case": "performedDateTime (not Period)",
      "handling": "Date part goes to procedure_date/procedure_datetime. procedure_end_date: ETL-German leaves null, NACHC sets end = start.",
      "implementations": [
        "ETL-German",
        "NACHC",
        "omoponfhir"
      ]
    },
    {
      "case": "Procedure.category present",
      "handling": "Could inform procedure_type_concept_id, but no implementation uses it. omoponfhir has commented-out code for this."
    }
  ]
