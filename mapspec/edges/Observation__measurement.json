    {
      "case": "Missing code.coding",
      "handling": "Skip entire observation."
    },
    {
      "case": "LOINC code not in OMOP vocabulary",
      "handling": "measurement_concept_id=0. Code preserved in measurement_source_value."
    },
    {
      "case": "Multiple referenceRange entries",
      "handling": "Only first range used."
    },
    {
      "case": "valueBoolean, valueInteger, valueRange, valueRatio",
      "handling": "Not mapped. Could be coerced to value_as_number or value_source_value."
    }
  ]
}
