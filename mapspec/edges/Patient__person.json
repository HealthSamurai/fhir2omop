{
  "$schema": "../schema/edge.schema.json",
  "fhir_resource": "Patient",
  "omop_table": "person",
  "direction": "fhir-to-omop",
  "status": "implemented",
  "primary": true,
  "required": true,
  "narrative_md": "Core demographics record. One FHIR Patient maps to exactly one OMOP person row. The person table is the central identity record — every OMOP event table carries a person_id FK.",
  "fields": [
    {
      "omop_column": "person_id",
      "fhir_path": "Patient.id",
      "fhir_type": "id",
      "omop_type": "integer",
      "required": true,
      "pk": true,
      "notes": "Surrogate key. Hash/sequence/lookup of Patient.id. HL7 IG FML leaves this as a TODO.",
      "sources": [
        {
          "comment": "TODO/commented placeholder — no concrete strategy",
          "references": [
            {
              "project": "fhir-omop-ig",
              "kind": "fml",
              "path": "refs/refs/fhir-omop-ig/input/maps/PersonMap.fml"
            }
          ]
        },
        {
          "comment": "Direct copy from FPerson primary key",
          "references": [
            {
              "project": "omoponfhir",
              "kind": "java",
              "path": "refs/refs/omoponfhir-omopv5-r4-mapping/src/main/java/edu/gatech/chai/omoponfhir/omopv5/r4/mapping/OmopPatient.java"
            }
          ]
        },
        {
          "comment": "Auto-incrementing sequence",
          "references": [
            {
              "project": "FhirToCdm",
              "kind": "csharp",
              "path": "refs/refs/FhirToCdm/FhirToCdmMappings.cs",
              "lines": [
                20,
                170
              ],
              "notes": "CreatePersonAndLocations()"
            },
            {
              "project": "ETL-German-FHIR-Core",
              "kind": "java",
              "path": "refs/refs/ETL-German-FHIR-Core/src/main/java/org/miracum/etl/fhirtoomop/mapper/PatientMapper.java"
            },
            {
              "project": "NACHC-fhir-to-omop",
              "kind": "java",
              "path": "refs/refs/NACHC-fhir-to-omop/src/main/java/org/nachc/tools/fhirtoomop/omop/person/factory/builder/person/OmopPersonBuilder.java"
            }
          ]
        },
        {
          "comment": "Reuse Patient.id verbatim as integer",
          "references": [
            {
              "project": "fhir-to-omop-demo",
              "kind": "jq",
              "path": "refs/refs/fhir-to-omop-demo/demo/translate/map/Patient.jq"
            }
          ]
        }
      ]
    },
    {
      "omop_column": "gender_concept_id",
      "fhir_path": "Patient.gender",
      "fhir_type": "code",
      "omop_type": "integer",
      "required": true,
      "fk": "CONCEPT",
      "concept_map": "gender",
      "notes": "male→8507, female→8532, other→8521, unknown→8551, absent→0",
      "sources": [
        {
          "comment": "Standard concept_id lookup (8507/8532/8521/8551/0)",
          "references": [
            {
              "project": "omoponfhir",
              "kind": "java",
              "path": "refs/refs/omoponfhir-omopv5-r4-mapping/src/main/java/edu/gatech/chai/omoponfhir/omopv5/r4/mapping/OmopPatient.java",
              "lines": [
                201,
                213
              ]
            },
            {
              "project": "mends-on-fhir",
              "kind": "whistle-conceptmap",
              "path": "refs/refs/mends-on-fhir/whistle-mappings/synthea/concept-maps/Person.gender.conceptid.json"
            }
          ]
        },
        {
          "comment": "Pass-through FHIR code without translation (non-normative)",
          "references": [
            {
              "project": "fhir-omop-ig",
              "kind": "fml",
              "path": "refs/refs/fhir-omop-ig/input/maps/PersonMap.fml"
            }
          ]
        },
        {
          "comment": "Switch on code with 0 fallback for unknown/other",
          "references": [
            {
              "project": "FhirToCdm",
              "kind": "csharp",
              "path": "refs/refs/FhirToCdm/FhirToCdmMappings.cs",
              "lines": [
                50,
                63
              ]
            }
          ]
        },
        {
          "comment": "Concept lookup including German extension support",
          "references": [
            {
              "project": "ETL-German-FHIR-Core",
              "kind": "java",
              "path": "refs/refs/ETL-German-FHIR-Core/src/main/java/org/miracum/etl/fhirtoomop/mapper/PatientMapper.java",
              "lines": [
                607,
                641
              ]
            }
          ]
        },
        {
          "comment": "Prefer us-core-birthsex extension over Patient.gender",
          "references": [
            {
              "project": "fhir-to-omop-demo",
              "kind": "jq",
              "path": "refs/refs/fhir-to-omop-demo/demo/translate/map/Patient.jq"
            }
          ]
        },
        {
          "comment": "Null when no mapping found",
          "references": [
            {
              "project": "NACHC-fhir-to-omop",
              "kind": "java",
              "path": "refs/refs/NACHC-fhir-to-omop/src/main/java/org/nachc/tools/fhirtoomop/util/mapping/GenderMapping.java"
            }
          ]
        }
      ]
    },
    {
      "omop_column": "gender_source_value",
      "fhir_path": "Patient.gender",
      "fhir_type": "code",
      "omop_type": "varchar(50)"
    },
    {
      "omop_column": "gender_source_concept_id",
      "fhir_path": null,
      "fhir_type": "code",
      "omop_type": "integer",
      "constant": 0
    },
    {
      "omop_column": "year_of_birth",
      "fhir_path": "Patient.birthDate",
      "fhir_type": "date",
      "omop_type": "integer",
      "required": true,
      "transform": "year(Patient.birthDate)"
    },
    {
      "omop_column": "month_of_birth",
      "fhir_path": "Patient.birthDate",
      "fhir_type": "date",
      "omop_type": "integer",
      "transform": "month(Patient.birthDate)"
    },
    {
      "omop_column": "day_of_birth",
      "fhir_path": "Patient.birthDate",
      "fhir_type": "date",
      "omop_type": "integer",
      "transform": "day(Patient.birthDate)"
    },
    {
      "omop_column": "birth_datetime",
      "fhir_path": "Patient.birthDate + patient-birthTime extension",
      "fhir_type": "dateTime",
      "omop_type": "datetime"
    },
    {
      "omop_column": "race_concept_id",
      "fhir_path": "Patient.extension[us-core-race].ombCategory",
      "fhir_type": "code",
      "omop_type": "integer",
      "required": true,
      "fk": "CONCEPT",
      "concept_map": "race"
    },
    {
      "omop_column": "race_source_value",
      "fhir_path": "Patient.extension[us-core-race].ombCategory.display",
      "fhir_type": "code",
      "omop_type": "varchar(50)"
    },
    {
      "omop_column": "race_source_concept_id",
      "fhir_path": null,
      "fhir_type": "code",
      "omop_type": "integer",
      "constant": 0,
      "notes": "Intentionally 0. OMOP CDM v5.4 user_guidance: 'Due to the small number of options, this tends to be zero. If the source data codes race in an OMOP supported vocabulary store the concept_id here.' US Core / OMB race codes (2106-3, 2054-5, 2028-9, 1002-5, 2076-8) are NOT loaded as concept_codes under any race vocabulary in Athena — the OMOP Race vocab uses integer codes 1-5/9/UNK (e.g. concept_code='5' for White). So an OMB source code has no Athena counterpart; 0 is the spec-recommended value."
    },
    {
      "omop_column": "ethnicity_concept_id",
      "fhir_path": "Patient.extension[us-core-ethnicity].ombCategory",
      "fhir_type": "code",
      "omop_type": "integer",
      "required": true,
      "fk": "CONCEPT",
      "concept_map": "ethnicity"
    },
    {
      "omop_column": "ethnicity_source_value",
      "fhir_path": "Patient.extension[us-core-ethnicity].ombCategory.display",
      "fhir_type": "code",
      "omop_type": "varchar(50)"
    },
    {
      "omop_column": "ethnicity_source_concept_id",
      "fhir_path": null,
      "fhir_type": "code",
      "omop_type": "integer",
      "constant": 0,
      "notes": "Intentionally 0. OMOP CDM v5.4 user_guidance: 'Due to the small number of options, this tends to be zero.' OMB ethnicity codes (2186-5 Not Hispanic, 2135-2 Hispanic) are not concept_codes in Athena's Ethnicity vocab; the standard concepts there use codes 'Hispanic' / 'Not Hispanic' (38003563/4). 0 is the spec-recommended value."
    },
    {
      "omop_column": "location_id",
      "fhir_path": "Patient.address",
      "fhir_type": "Address",
      "omop_type": "integer",
      "fk": "LOCATION"
    },
    {
      "omop_column": "provider_id",
      "fhir_path": "Patient.generalPractitioner[0] (Practitioner)",
      "fhir_type": "Reference(Practitioner)",
      "omop_type": "integer",
      "fk": "PROVIDER"
    },
    {
      "omop_column": "care_site_id",
      "fhir_path": "Patient.managingOrganization",
      "fhir_type": "Reference(Organization)",
      "omop_type": "integer",
      "fk": "CARE_SITE"
    },
    {
      "omop_column": "person_source_value",
      "fhir_path": "Patient.id",
      "fhir_type": "id",
      "omop_type": "varchar(50)",
      "notes": "Traceability key, NOT a clinical identifier. OMOP CDM v5.4 spec (user_guidance): 'Use this field to link back to persons in the source data. This is typically used for error checking of ETL logic.' We write Patient.id (the FHIR resource UUID) — the canonical 'where did this row come from' anchor. Synthea also emits PHI identifiers (SS, MR, DL, PPN) in Patient.identifier[], but those are intentionally NOT used here; per OHDSI privacy guidance they belong in a separate id-mapping table, not in person_source_value."
    }
  ],
