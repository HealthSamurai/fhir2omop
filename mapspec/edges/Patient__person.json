  "edge_cases": [
    {
      "case": "Missing birthDate",
      "handling": "OMOP convention: drop person. Most implementations write year_of_birth=0.",
      "implementations": [
        "ETL-German",
        "NACHC",
        "omoponfhir"
      ]
    },
    {
      "case": "Partial birthDate (year-only or year-month)",
      "handling": "Year always populated; month/day null when not provided. birth_datetime null if incomplete."
    },
    {
      "case": "Missing gender",
      "handling": "gender_concept_id=0, gender_source_value=null. Per OMOP Themis, use 0 rather than 8551."
    },
    {
      "case": "Multiple identifiers",
      "handling": "Pick best by priority: SSN > MR > first. Encoding varies across implementations."
    },
    {
      "case": "Multiple generalPractitioner entries",
      "handling": "Filter to Practitioner references only. Take last (most recent) or first."
    },
    {
      "case": "Multi-race patient (multiple ombCategory entries)",
      "handling": "OMOP has single race_concept_id. Pick first, or use 8522 (Other), or write 0."
    },
    {
      "case": "deceasedBoolean=true without date",
      "handling": "Cannot create death row. See Patient__death edge."
    },
    {
      "case": "Multiple address entries",
      "handling": "Pick most recent home address. See Patient__location edge."
    }
  ]
}
