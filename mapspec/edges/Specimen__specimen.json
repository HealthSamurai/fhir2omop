{
  "$schema": "../schema/edge.schema.json",
  "fhir_resource": "Specimen",
  "omop_table": "specimen",
  "direction": "fhir-to-omop",
  "status": "documented",
  "primary": true,
  "required": true,
  "narrative_md": "One FHIR Specimen maps to exactly one OMOP specimen row. The specimen table captures biological samples collected from a person, including specimen type, collection date, quantity, anatomic site, and disease status. Specimen type (kind of material) maps to specimen_concept_id via SNOMED, while specimen_type_concept_id is a provenance metadata field (EHR = 32817). Collection date is required in OMOP but optional in FHIR.",
  "implementation_in_project": null,
  "fields": [
    {
      "omop_column": "specimen_id",
      "fhir_path": "Specimen.id",
      "fhir_type": "id",
      "omop_type": "integer",
      "required": true,
      "pk": true,
      "transform": "hash_or_sequence(Specimen.id)",
      "notes": "Surrogate key. Hash/sequence/lookup of Specimen.id. Store FHIR ID or first identifier in specimen_source_id for traceability."
    },
    {
      "omop_column": "person_id",
      "fhir_path": "Specimen.subject",
      "fhir_type": "Reference(Patient)",
      "omop_type": "integer",
      "required": true,
      "fk": "PERSON",
      "transform": "resolve_patient_reference(Specimen.subject)",
      "notes": "Resolve Patient reference to integer person_id. Subject must be a Patient -- reject Device, Group, Location, Substance subjects."
    },
    {
      "omop_column": "specimen_concept_id",
      "fhir_path": "Specimen.type",
      "fhir_type": "CodeableConcept",
      "omop_type": "integer",
      "required": true,
      "fk": "CONCEPT",
      "concept_map": "specimen_type",
      "notes": "Map to OMOP concept in Specimen domain. Prefer SNOMED coding if multiple codings present. Fall back to 0 if no mapping found.",
      "sources": [
        {
          "comment": "SNOMED-preferred multi-coding lookup via ConceptService; iterates codings, picks SNOMED first",
          "references": [
            { "project": "omoponfhir-v54", "kind": "java", "path": "refs/refs/omoponfhir-v54-r4/omoponfhir-omopv5-r4-mapping/src/main/java/edu/gatech/chai/omoponfhir/omopv5/r4/mapping/OmopSpecimen.java", "lines": [264, 312] }
          ]
        },
        {
          "comment": "Logical model only — no FML transform for Specimen; field defined but not implemented",
          "references": [
            { "project": "fhir-omop-ig", "kind": "fsh", "path": "refs/refs/fhir-omop-ig/input/fsh/Specimen.fsh", "lines": [1, 22] }
          ]
        }
      ]
    },
    {
      "omop_column": "specimen_type_concept_id",
      "fhir_path": null,
      "fhir_type": "constant",
      "omop_type": "integer",
      "required": true,
      "fk": "CONCEPT",
      "constant": 32817,
      "notes": "Provenance of the specimen record, not the kind of specimen. Set to 32817 (EHR) for EHR-sourced data. omoponfhir hardcodes 0.",
      "sources": [
        {
          "comment": "Hardcoded to 0 — provenance not captured",
          "references": [
            { "project": "omoponfhir-v54", "kind": "java", "path": "refs/refs/omoponfhir-v54-r4/omoponfhir-omopv5-r4-mapping/src/main/java/edu/gatech/chai/omoponfhir/omopv5/r4/mapping/OmopSpecimen.java", "lines": [387, 387], "notes": "specimen_.setSpecimenTypeConcept(new Concept(0L))" }
          ]
        },
        {
          "comment": "32817 (EHR) — recommended for EHR-sourced FHIR data",
          "references": [
            { "project": "fhir-omop-ig", "kind": "fsh", "path": "refs/refs/fhir-omop-ig/input/fsh/Specimen.fsh", "lines": [1, 22], "notes": "field defined in logical model as provenance concept" }
          ]
        }
      ]
    },
    {
      "omop_column": "specimen_date",
      "fhir_path": "Specimen.collection.collected[x]",
      "fhir_type": "dateTime | Period",
      "omop_type": "date",
      "required": true,
      "transform": "date_component(collected[x]); if Period use Period.start; fallback to Specimen.receivedTime",
      "notes": "OMOP requires this field (NOT NULL). If collected[x] is a Period, use Period.start. If absent, try Specimen.receivedTime as fallback.",
      "sources": [
        {
          "comment": "collectedDateTime only — throws FHIRException if absent or if type is Period",
          "references": [
            { "project": "omoponfhir-v54", "kind": "java", "path": "refs/refs/omoponfhir-v54-r4/omoponfhir-omopv5-r4-mapping/src/main/java/edu/gatech/chai/omoponfhir/omopv5/r4/mapping/OmopSpecimen.java", "lines": [330, 342] },
            { "project": "omoponfhir-v54", "kind": "java", "path": "refs/refs/omoponfhir-v54-r4/omoponfhir-r4-server/src/main/java/edu/gatech/chai/omoponfhir/r4/provider/SpecimenResourceProvider.java", "lines": [269, 285] }
          ]
        },
        {
          "comment": "Maps specimen_date from OMOP (O→F direction); no FHIR→OMOP date extraction logic",
          "references": [
            { "project": "tofhir-mappings", "kind": "json", "path": "refs/refs/tofhir-mappings/mappings/omop/specimen-mapping.json", "lines": [44, 61] }
          ]
        }
      ]
    },
    {
      "omop_column": "specimen_datetime",
      "fhir_path": "Specimen.collection.collected[x]",
      "fhir_type": "dateTime | Period",
      "omop_type": "datetime",
      "required": false,
      "transform": "full_datetime(collected[x]); if date-only append T00:00:00",
      "notes": "Full datetime of collection. Same source as specimen_date but preserves time component."
    },
    {
      "omop_column": "quantity",
      "fhir_path": "Specimen.collection.quantity.value",
      "fhir_type": "decimal",
      "omop_type": "float",
      "required": false,
      "notes": "Amount of specimen collected. Direct numeric copy from collection.quantity.value."
    },
    {
      "omop_column": "unit_concept_id",
      "fhir_path": "Specimen.collection.quantity",
      "fhir_type": "Quantity",
      "omop_type": "integer",
      "required": false,
      "fk": "CONCEPT",
      "concept_map": "ucum_unit",
      "transform": "lookup_ucum(quantity.code where quantity.system = 'http://unitsofmeasure.org')",
      "notes": "Look up UCUM code in CONCEPT table (vocabulary_id = 'UCUM'). Default 0 if lookup fails."
    },
    {
      "omop_column": "unit_source_value",
      "fhir_path": "Specimen.collection.quantity.unit",
      "fhir_type": "string",
      "omop_type": "varchar(50)",
      "required": false,
      "notes": "Raw unit string. Prefer quantity.unit (human-readable); fall back to quantity.code (UCUM code)."
    },
    {
      "omop_column": "anatomic_site_concept_id",
      "fhir_path": "Specimen.collection.bodySite",
      "fhir_type": "CodeableConcept",
      "omop_type": "integer",
      "required": false,
      "fk": "CONCEPT",
      "concept_map": "anatomic_site",
      "notes": "SNOMED body site code mapped to OMOP concept. Use first coding from bodySite.coding[]. Default 0 if unmapped."
    },
    {
      "omop_column": "anatomic_site_source_value",
      "fhir_path": "Specimen.collection.bodySite.text",
      "fhir_type": "string",
      "omop_type": "varchar(50)",
      "required": false,
      "notes": "Source text for anatomic site. Prefer bodySite.text, then coding[0].display, then coding[0].code."
    },
    {
      "omop_column": "disease_status_concept_id",
      "fhir_path": "Specimen.condition",
      "fhir_type": "CodeableConcept",
      "omop_type": "integer",
      "required": false,
      "fk": "CONCEPT",
      "constant": 0,
      "notes": "Semantic mismatch: FHIR condition describes specimen quality (hemolyzed, lipemic), not patient disease status. Most implementations set 0."
    },
    {
      "omop_column": "disease_status_source_value",
      "fhir_path": "Specimen.condition.text",
      "fhir_type": "string",
      "omop_type": "varchar(50)",
      "required": false,
      "notes": "Source text for disease/condition status. Prefer condition.text, then coding[0].display, then coding[0].code."
    },
    {
      "omop_column": "specimen_source_id",
      "fhir_path": "Specimen.identifier[0].value",
      "fhir_type": "string",
      "omop_type": "varchar(50)",
      "required": false,
      "notes": "Source system identifier. omoponfhir uses first identifier value. Can also use Specimen.accessionIdentifier.value.",
      "sources": [
        {
          "comment": "First Specimen.identifier value (not accessionIdentifier)",
          "references": [
            { "project": "omoponfhir-v54", "kind": "java", "path": "refs/refs/omoponfhir-v54-r4/omoponfhir-omopv5-r4-mapping/src/main/java/edu/gatech/chai/omoponfhir/omopv5/r4/mapping/OmopSpecimen.java", "lines": [247, 252] }
          ]
        },
        {
          "comment": "Hashed specimen_id string (O→F direction, not FHIR identifier)",
          "references": [
            { "project": "tofhir-mappings", "kind": "json", "path": "refs/refs/tofhir-mappings/mappings/omop/specimen-mapping.json", "lines": [33, 33] }
          ]
        }
      ]
    },
    {
      "omop_column": "specimen_source_value",
      "fhir_path": "Specimen.type.text",
      "fhir_type": "string",
      "omop_type": "varchar(50)",
      "required": false,
      "notes": "Verbatim source code/text for the specimen type. Populated when specimen_concept_id is 0 (unmapped). Use type.text if available, otherwise system|code or display of first coding, truncated to 50 chars."
    }
  ],
