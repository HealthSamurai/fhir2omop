  "edge_cases": [
    {
      "case": "Missing collection.collected[x]",
      "handling": "OMOP specimen_date is NOT NULL. Options: (a) reject the resource and log warning, (b) fall back to Specimen.receivedTime, (c) use current date (not recommended). omoponfhir throws FHIRException.",
      "implementations": ["omoponfhir-v54"]
    },
    {
      "case": "collected[x] is a Period",
      "handling": "OMOP only supports a single date/datetime, not a range. Use Period.start as the collection date. Period.end is lost. omoponfhir throws if collected is not a DateTimeType.",
      "implementations": ["omoponfhir-v54"]
    },
    {
      "case": "subject references non-Patient (Device, Group, Location, Substance)",
      "handling": "Reject the resource. OMOP person_id requires a patient. Log warning with the unsupported resource type.",
      "implementations": ["omoponfhir-v54"]
    },
    {
      "case": "subject reference unresolvable (Patient not yet in OMOP)",
      "handling": "Either: (a) process Patients first (dependency ordering), (b) defer Specimen to a retry queue, (c) reject. omoponfhir throws FHIRException if patient lookup returns null.",
      "implementations": ["omoponfhir-v54"]
    },
    {
      "case": "Missing Specimen.type",
      "handling": "Set specimen_concept_id to 0 and leave specimen_source_value empty. omoponfhir treats type as required via the coding iteration logic -- null type will cause NPE.",
      "implementations": ["omoponfhir-v54"]
    },
    {
      "case": "Multiple codings in Specimen.type",
      "handling": "Prefer SNOMED CT coding (http://snomed.info/sct). If no SNOMED, try any coding that maps to a known OMOP vocabulary. If none map, use concept_id 0.",
      "implementations": ["omoponfhir-v54"]
    },
    {
      "case": "Specimen.type uses HL7 v2 Table 0487",
      "handling": "These codes (BLD, UR, TISS, etc.) are in the 'v2 Specimen Type' vocabulary in OMOP. Look up via vocabulary_id = 'v2 Specimen Type'. If not found, set 0 and preserve in source_value."
    },
    {
      "case": "Specimen.parent (aliquot/derived specimen)",
      "handling": "No OMOP field for parent-child specimen relationships. Lost in mapping. Could potentially be captured in fact_relationship with a custom relationship concept."
    },
    {
      "case": "Specimen.status = entered-in-error",
      "handling": "OMOP has no status field on specimen. Options: (a) skip the resource entirely (recommended), (b) insert anyway (bad data quality)."
    },
    {
      "case": "Quantity without unit",
      "handling": "Set unit_concept_id = 0, unit_source_value = null. The quantity value is still stored."
    },
    {
      "case": "disease_status_concept_id semantic mismatch",
      "handling": "FHIR Specimen.condition describes specimen quality (hemolyzed, clotted), not patient disease status. Most implementations set 0. If a clinical use case requires mapping, use vocabulary lookup for SNOMED or v2 codes."
    },
    {
      "case": "Duplicate specimens",
      "handling": "omoponfhir deduplicates on (patient, specimen_concept, collection_date) tuple. If a matching specimen exists, it updates rather than creating a duplicate. Other implementations do not deduplicate.",
      "implementations": ["omoponfhir-v54"]
    },
    {
      "case": "specimen_source_id truncation",
      "handling": "OMOP field is varchar(50). FHIR identifiers (especially UUIDs in urn:uuid: format) can exceed 50 characters. Truncate or hash if necessary."
    }
  ]
}
