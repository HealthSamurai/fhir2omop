      "implementations": [
        "this-project",
        "ETL-German"
      ]
    },
    {
      "case": "Missing period.end",
      "handling": "Use visit_start_date as visit_end_date.",
      "implementations": [
        "this-project",
        "NACHC",
        "FhirToCdm"
      ]
    },
    {
      "case": "Status = planned / cancelled / entered-in-error",
      "handling": "Skip -- only finished and in-progress encounters produce rows.",
      "implementations": [
        "this-project",
        "ETL-German"
      ]
    },
    {
      "case": "Status = unknown with no end date",
      "handling": "ETL-German treats as CONCEPT_STILL_PATIENT and sets end date to now().",
      "implementations": [
        "ETL-German"
      ]
    },
    {
