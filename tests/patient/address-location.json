[
  {
    "description": "home-адрес выбирается для LOCATION",
    "spec": "mapping/patient/address-location.md",
    "fhir": [
      {
        "resourceType": "Patient",
        "id": "pt-1",
        "birthDate": "1990-01-01",
        "address": [
          {"use": "work", "city": "WorkCity"},
          {"use": "home", "city": "HomeCity", "state": "OR"}
        ]
      }
    ],
    "omop": [
      {"table": "person"},
      {"table": "location", "city": "HomeCity", "state": "OR"}
    ]
  },
  {
    "description": "несколько home-адресов → последний (самый актуальный)",
