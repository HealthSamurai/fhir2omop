        "provider_id": 1
      }
    ]
  },
  {
    "description": "managingOrganization → care_site_id",
    "spec": "mapping/patient/references.md",
    "fhir": [
      {
        "resourceType": "Patient",
        "id": "pt-2",
        "birthDate": "1990-01-01",
        "managingOrganization": {"reference": "Organization/7"}
      }
    ],
    "omop": [
      {
        "table": "person",
        "care_site_id": 1
      }
    ]
  },
  {
    "description": "multiple generalPractitioner → first one is used",
    "comment": "OMOP PERSON has a single provider_id field. We use generalPractitioner[0].",
    "spec": "mapping/patient/references.md",
    "fhir": [
      {
        "resourceType": "Patient",
        "id": "pt-3",
        "birthDate": "1990-01-01",
        "generalPractitioner": [
          {"reference": "Practitioner/10"},
          {"reference": "Practitioner/20"}
        ]
      }
    ],
    "omop": [
      {
        "table": "person",
        "provider_id": 1
      }
    ]
  },
  {
    "description": "references missing → provider_id and care_site_id = null",
    "comment": "No default values (like 1) are used. NULL correctly reflects missing data.",
    "spec": "mapping/patient/references.md",
    "fhir": [
      {
        "resourceType": "Patient",
        "id": "pt-4",
        "birthDate": "1990-01-01"
      }
    ],
    "omop": [
      {
        "table": "person",
        "provider_id": null,
        "care_site_id": null
      }
    ]
  },
  {
    "description": "both references populated",
    "spec": "mapping/patient/references.md",
    "fhir": [
      {
        "resourceType": "Patient",
        "id": "pt-5",
        "birthDate": "1990-01-01",
        "generalPractitioner": [
          {"reference": "Practitioner/100"}
        ],
        "managingOrganization": {"reference": "Organization/50"}
      }
    ],
    "omop": [
      {
        "table": "person",
        "provider_id": 1,
        "care_site_id": 1
      }
    ]
  },
  {
    "description": "UUID references work through IdRegistry",
    "comment": "FHIR ID can be UUID — IdRegistry assigns integer IDs.",
    "spec": "mapping/patient/references.md",
    "fhir": [
      {
        "resourceType": "Patient",
        "id": "pt-6",
        "birthDate": "1990-01-01",
        "generalPractitioner": [
          {"reference": "Practitioner/a1b2c3d4-e5f6-7890-abcd-ef1234567890"}
        ],
        "managingOrganization": {"reference": "Organization/xyz-org-uuid"}
      }
    ],
    "omop": [
      {
        "table": "person",
        "provider_id": 1,
        "care_site_id": 1
      }
    ]
  }
]
